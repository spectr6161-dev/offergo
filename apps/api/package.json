{
  "name": "@offergo/api",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/main.ts",
    "build": "tsc -p tsconfig.build.json",
    "start": "tsx dist/apps/api/src/main.js",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc -p tsconfig.json",
    "format:check": "prettier --check \"src/**/*.ts\""
  },
  "dependencies": {
    "@nestjs/common": "^11.1.6",
    "@nestjs/core": "^11.1.6",
    "@nestjs/platform-express": "^11.1.6",
    "@nestjs/swagger": "^11.2.3",
    "@offergo/auth": "workspace:*",
    "@offergo/billing": "workspace:*",
    "@offergo/db": "workspace:*",
    "@offergo/shared": "workspace:*",
    "better-auth": "^1.6.8",
    "express": "^5.1.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "swagger-ui-express": "^5.0.1",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@types/express": "^5.0.3",
    "@types/node": "^22.15.21",
    "eslint": "^9.39.1",
    "prettier": "^3.6.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
