{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "allowJs": true,
    "baseUrl": ".",
    "jsx": "react-jsx",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/*": ["./*"],
      "@offergo/shared": ["../../packages/shared/src/index.ts"],
      "@offergo/db": ["../../packages/db/src/index.ts"],
      "@offergo/auth": ["../../packages/auth/src/index.ts"],
      "@offergo/auth/client": ["../../packages/auth/src/client.ts"],
      "@offergo/auth/server": ["../../packages/auth/src/server.ts"],
      "@offergo/auth/core": ["../../packages/auth/src/core.ts"],
      "@offergo/ui": ["../../packages/ui/src/index.tsx"],
      "@offergo/ai": ["../../packages/ai/src/index.ts"],
      "@offergo/billing": ["../../packages/billing/src/index.ts"],
      "@offergo/queue": ["../../packages/queue/src/index.ts"]
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts",
    "**/*.mts"
  ],
  "exclude": ["node_modules"]
}
