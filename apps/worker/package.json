    "@offergo/queue": "workspace:*",
    "@offergo/shared": "workspace:*",
    "bullmq": "^5.63.0",
    "ioredis": "^5.8.1",
    "playwright": "^1.55.1",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@types/node": "^22.15.21",
    "eslint": "^9.39.1",
    "prettier": "^3.6.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
