{
  "name": "@offergo/worker",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json --outDir dist",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc -p tsconfig.json",
    "format:check": "prettier --check \"src/**/*.ts\""
  },
  "dependencies": {
    "@offergo/ai": "workspace:*",
