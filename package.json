{
  "name": "offergo-app",
  "private": true,
  "packageManager": "pnpm@10.33.2",
  "scripts": {
    "dev": "turbo dev --parallel",
    "dev:web": "pnpm --filter @offergo/web dev",
    "dev:api": "pnpm --filter @offergo/api dev",
    "dev:worker": "pnpm --filter @offergo/worker dev",
    "build": "pnpm db:generate && turbo build",
    "lint": "turbo lint",
    "typecheck": "pnpm db:generate && turbo typecheck",
    "format:check": "turbo format:check",
    "legal:sync": "node scripts/sync-legal-documents.mjs",
    "db:generate": "pnpm --filter @offergo/db db:generate",
    "db:migrate": "pnpm --filter @offergo/db db:migrate",
    "db:seed": "pnpm --filter @offergo/db db:seed",
    "docker:setup": "powershell -ExecutionPolicy Bypass -File scripts/project.ps1 setup",
    "docker:dev": "powershell -ExecutionPolicy Bypass -File scripts/project.ps1 dev",
    "docker:build": "powershell -ExecutionPolicy Bypass -File scripts/project.ps1 build",
    "docker:seed": "powershell -ExecutionPolicy Bypass -File scripts/project.ps1 seed",
    "docker:deploy": "powershell -ExecutionPolicy Bypass -File scripts/project.ps1 deploy",
    "docker:restart": "powershell -ExecutionPolicy Bypass -File scripts/project.ps1 restart",
    "docker:logs": "powershell -ExecutionPolicy Bypass -File scripts/project.ps1 logs",
    "docker:ps": "powershell -ExecutionPolicy Bypass -File scripts/project.ps1 ps",
    "docker:health": "powershell -ExecutionPolicy Bypass -File scripts/project.ps1 health",
    "docker:clean": "powershell -ExecutionPolicy Bypass -File scripts/project.ps1 clean"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/node": "^22.15.21",
    "eslint": "^9.39.1",
    "globals": "^16.4.0",
    "mammoth": "^1.12.0",
    "prettier": "^3.6.2",
    "tsx": "^4.21.0",
    "turbo": "^2.5.8",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.46.2"
  },
  "pnpm": {
    "overrides": {
      "@tiptap/core": "2.27.2",
      "@tiptap/pm": "2.27.2"
    }
  }
}
