---
import Footer from "@/components/Footer.astro";
import Header from "@/components/Header.astro";
import { brand } from "@/data/site";
import "@/styles/global.css";

type JsonLd = Record<string, unknown> | Array<Record<string, unknown>>;

const siteOrigin = "https://offergo.ru";
const promoRoot = `${siteOrigin}/promo`;
const currentPath = Astro.url.pathname;

interface Props {
  title?: string;
  description?: string;
  canonicalPath?: string;
  robots?: string;
  ogImage?: string;
  jsonLd?: JsonLd;
  pageType?: string;
  hideHeader?: boolean;
  hideFooter?: boolean;
  hideTelegramFab?: boolean;
}

const {
  title = "offerGO - AI-помощник для IT-собеседований",
  description = "offerGO помогает готовиться к IT-собеседованиям, разбирать технические вопросы, улучшать резюме и быстрее находить подходящие вакансии.",
  canonicalPath,
  robots,
  ogImage,
  jsonLd,
  pageType = "website",
  hideHeader = false,
  hideFooter = false,
  hideTelegramFab = false,
} = Astro.props;

function toAbsoluteUrl(value: string) {
  if (/^https?:\/\//i.test(value)) {
    return value;
  }

  return new URL(value.startsWith("/") ? value : `/${value}`, siteOrigin).toString();
}

function stripTrailingSlash(value: string) {
  if (value === "/") {
    return value;
  }

  return value.replace(/\/+$/, "");
}

const showTelegramFab = !hideTelegramFab && !currentPath.startsWith("/promo/resume") && !currentPath.startsWith("/resume");
const noIndexPaths = ["/promo/auth", "/promo/account", "/promo/download"];
const canonicalUrl = toAbsoluteUrl(stripTrailingSlash(canonicalPath ?? currentPath));
const robotsContent = robots ?? (noIndexPaths.some((path) => currentPath.startsWith(path)) ? "noindex, nofollow" : "index, follow");
const resolvedOgImage = ogImage ? toAbsoluteUrl(ogImage) : undefined;
const extraJsonLd = jsonLd ? (Array.isArray(jsonLd) ? jsonLd : [jsonLd]) : [];
const pageName = title.replace(/\s[-—|]\s*offerGO$/i, "");
const contentSecurityPolicy = [
  "default-src 'self'",
  "script-src 'self' 'unsafe-inline'",
  "style-src 'self' 'unsafe-inline'",
  "img-src 'self' data: blob:",
  "font-src 'self' data:",
  "media-src 'self' data: blob:",
  "connect-src 'self' https://offergo.ru",
  "frame-src 'self'",
  "object-src 'none'",
  "base-uri 'self'",
  "form-action 'self' https://offergo.ru",
  "upgrade-insecure-requests",
].join("; ");
const baseJsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "Organization",
    "@id": `${promoRoot}#organization`,
    name: brand.name,
    url: promoRoot,
    logo: `${promoRoot}/favicon.svg`,
    sameAs: [brand.telegramUrl],
    contactPoint: [
      {
        "@type": "ContactPoint",
        email: brand.supportEmail,
        contactType: "customer support",
        availableLanguage: ["ru"],
      },
    ],
  },
  {
    "@context": "https://schema.org",
    "@type": "WebSite",
    "@id": `${promoRoot}#website`,
    name: brand.name,
    url: promoRoot,
    inLanguage: "ru-RU",
    publisher: {
      "@id": `${promoRoot}#organization`,
    },
    potentialAction: {
      "@type": "SearchAction",
      target: `${promoRoot}/questions?q={search_term_string}`,
      "query-input": "required name=search_term_string",
    },
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    itemListElement: [
      {
        "@type": "ListItem",
        position: 1,
        name: "Главная",
        item: promoRoot,
      },
      ...(canonicalUrl === promoRoot
        ? []
        : [
            {
              "@type": "ListItem",
              position: 2,
              name: pageName,
              item: canonicalUrl,
            },
          ]),
    ],
  },
];
const jsonLdItems = [...baseJsonLd, ...extraJsonLd];
---

<!doctype html>
<html lang="ru">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta http-equiv="Content-Security-Policy" content={contentSecurityPolicy} />
    <meta name="theme-color" content="#F5F8FD" />
    <script is:inline>
      (() => {
        const key = "offergo-theme";
        let theme = "light";

        try {
          const stored = window.localStorage.getItem(key);
          if (stored === "dark" || stored === "light") {
            theme = stored;
          }
        } catch {}

        document.documentElement.dataset.theme = theme;
        document.documentElement.style.colorScheme = theme;
      })();
    </script>
    <link rel="icon" type="image/svg+xml" href="/promo/favicon.svg" />
    <link rel="shortcut icon" href="/promo/favicon.svg" />
    <link rel="canonical" href={canonicalUrl} />
    <meta name="description" content={description} />
    <meta name="robots" content={robotsContent} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content={pageType} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:site_name" content={brand.name} />
    <meta property="og:locale" content="ru_RU" />
    {resolvedOgImage && <meta property="og:image" content={resolvedOgImage} />}
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    {resolvedOgImage && <meta name="twitter:image" content={resolvedOgImage} />}
    {jsonLdItems.map((item) => <script type="application/ld+json" set:html={JSON.stringify(item)} />)}
    <title>{title}</title>
  </head>
  <body>
    <a class="skip-link" href="#content">К содержимому</a>
    <div class="site-shell">
      {!hideHeader && <Header />}
      <main id="content">
        <slot />
      </main>
      {!hideFooter && <Footer />}
      {showTelegramFab && (
        <a class="telegram-fab" href={brand.telegramUrl} target="_blank" rel="noreferrer" aria-label="Открыть Telegram-канал">
          <svg viewBox="0 0 24 24" aria-hidden="true">
            <path d="M21.7 4.1 18.5 19c-.24 1.05-.88 1.3-1.78.8l-4.92-3.63-2.37 2.28c-.26.26-.48.48-.98.48l.35-5.02 9.13-8.25c.4-.35-.09-.55-.61-.2L6.03 12.56 1.17 11.04c-1.06-.33-1.08-1.06.22-1.57L20.4 2.15c.88-.32 1.65.2 1.3 1.95Z" />
          </svg>
        </a>
      )}
    </div>
    <script is:inline>
      const revealItems = document.querySelectorAll(".reveal");
      if (!window.matchMedia("(prefers-reduced-motion: reduce)").matches && "IntersectionObserver" in window) {
        const observer = new IntersectionObserver((entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              entry.target.classList.add("is-visible");
              observer.unobserve(entry.target);
            }
          });
        }, { threshold: 0.16 });
        revealItems.forEach((item) => observer.observe(item));
      } else {
        revealItems.forEach((item) => item.classList.add("is-visible"));
      }

      const downloadButtons = document.querySelectorAll("[data-download-installer]");
      downloadButtons.forEach((button) => {
        button.addEventListener("click", () => {
          if (!(button instanceof HTMLElement) || button.dataset.busy === "true") {
            return;
          }

          const label = button.querySelector("[data-download-label]");
          if (!(label instanceof HTMLElement)) {
            return;
          }

          const idleLabel = button.dataset.idleLabel || label.textContent || "";
          const loadingLabel = button.dataset.loadingLabel || "Пожалуйста, подождите";
          button.dataset.busy = "true";
          button.classList.add("is-busy");
          label.textContent = loadingLabel;

          window.setTimeout(() => {
            label.textContent = "Загрузка началась";
          }, 1200);

          window.setTimeout(() => {
            label.textContent = idleLabel;
            button.classList.remove("is-busy");
            delete button.dataset.busy;
          }, 5200);
        });
      });

      const themeMeta = document.querySelector('meta[name="theme-color"]');
      const themeButtons = document.querySelectorAll("[data-theme-toggle]");
      const THEME_KEY = "offergo-theme";

      const applyTheme = (theme) => {
        document.documentElement.dataset.theme = theme;
        document.documentElement.style.colorScheme = theme;

        try {
          window.localStorage.setItem(THEME_KEY, theme);
        } catch {}

        if (themeMeta instanceof HTMLMetaElement) {
          themeMeta.setAttribute("content", theme === "dark" ? "#03050A" : "#F5F8FD");
        }

        const nextTheme = theme === "dark" ? "light" : "dark";
        const nextLabel = nextTheme === "dark" ? "Включить тёмную тему" : "Включить светлую тему";

        themeButtons.forEach((button) => {
          if (!(button instanceof HTMLButtonElement)) {
            return;
          }

          button.setAttribute("aria-label", nextLabel);
          button.setAttribute("title", nextLabel);
        });
      };

      const initialTheme = document.documentElement.dataset.theme === "dark" ? "dark" : "light";
      applyTheme(initialTheme);

      themeButtons.forEach((button) => {
        button.addEventListener("click", () => {
          const currentTheme = document.documentElement.dataset.theme === "dark" ? "dark" : "light";
          applyTheme(currentTheme === "dark" ? "light" : "dark");
        });
      });
    </script>
  </body>
</html>

<style>
  .telegram-fab {
    position: fixed;
    right: 28px;
    bottom: 28px;
    z-index: 60;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 58px;
    height: 58px;
    border: 1px solid rgba(255, 255, 255, 0.18);
    border-radius: 999px;
    background: linear-gradient(180deg, #2aabee 0%, #229ed9 100%);
    box-shadow: 0 16px 40px rgba(34, 158, 217, 0.28);
    transition:
      transform 180ms var(--ease),
      box-shadow 180ms var(--ease),
      filter 180ms var(--ease);
  }

  .telegram-fab:hover {
    transform: translateY(-2px);
    box-shadow: 0 20px 48px rgba(34, 158, 217, 0.34);
    filter: saturate(1.06);
  }

  .telegram-fab:focus-visible {
    outline: 3px solid rgba(96, 165, 250, 0.6);
    outline-offset: 4px;
  }

  .telegram-fab svg {
    width: 25px;
    height: 25px;
    fill: #fff;
  }

  @media (max-width: 900px) {
    .telegram-fab {
      display: none;
    }
  }
</style>
