---
const features = [
  {
    title: "Автоподача",
    description:
      "Автоматизируйте поиск. offerGO откликается на сотни подходящих вакансий ежедневно, пока вы готовитесь к собеседованиям.",
    mock: "autoApply",
  },
  {
    title: "ИИ-конструктор резюме",
    description:
      "Создавайте ATS-оптимизированные резюме под каждую вакансию. ИИ подчеркнёт ваши лучшие навыки для большего числа собеседований.",
    mock: "resumeBuilder",
  },
  {
    title: "ИИ сопр. письма",
    description:
      "Создавайте персональные письма за секунды. Каждое — под требования вакансии, показывая, почему вы идеальный кандидат.",
    mock: "coverLetter",
  },
  {
    title: "Тренировка с ИИ",
    description:
      "Симулируйте реальные интервью с ИИ. Вопросы под вашу роль, мгновенная обратная связь и уверенность на собеседовании.",
    mock: "training",
  },
  {
    title: "Interview Buddy",
    description:
      "Получайте помощь ИИ прямо на собеседовании. Подсказки и ответы в реальном времени через наушники и экран.",
    mock: "buddy",
  },
  {
    title: "Перевод резюме",
    description:
      "Расширьте возможности глобально. Профессиональный перевод резюме на 50+ языков с сохранением форматирования и смысла.",
    mock: "translate",
  },
] as const;

const baseMockClass =
  "relative mt-7 h-[205px] overflow-hidden rounded-[20px] shadow-[0_18px_42px_rgba(15,23,42,0.14)] ring-1 ring-slate-900/5 dark:shadow-[0_22px_54px_rgba(0,0,0,0.36)] dark:ring-white/10";
---

<section
  class="bg-[#f3f3f2] px-5 py-10 text-slate-950 dark:bg-[#03050a] dark:text-white sm:px-7 sm:py-12 lg:py-14"
  aria-labelledby="resume-it-features-title"
>
  <div class="mx-auto w-full max-w-[1500px]">
    <h2
      id="resume-it-features-title"
      class="mx-auto max-w-5xl text-center text-[clamp(1.9rem,2.8vw,3.1rem)] font-semibold leading-[1.04] tracking-[-0.055em]"
    >
      Всё для быстрого трудоустройства!
    </h2>

    <div class="mt-16 grid gap-x-16 gap-y-16 md:grid-cols-2 lg:mt-20 lg:grid-cols-3 xl:gap-x-24 xl:gap-y-20">
      {
        features.map((feature) => (
          <article class="min-w-0">
            <h3 class="text-[1.38rem] font-semibold leading-tight tracking-[-0.04em] text-slate-950 dark:text-white">
              {feature.title}
            </h3>
            <p class="mt-4 max-w-[22rem] text-[0.98rem] leading-relaxed text-slate-700 dark:text-slate-300">
              {feature.description}
            </p>

            {feature.mock === "autoApply" && (
              <div
                class:list={[
                  baseMockClass,
                  "bg-[radial-gradient(circle_at_20%_25%,#fb3517_0_17%,transparent_18%),linear-gradient(135deg,#ff1584_0%,#ff3b6e_38%,#ff8f1f_100%)] dark:bg-[radial-gradient(circle_at_20%_25%,rgba(251,53,23,0.72)_0_17%,transparent_18%),linear-gradient(135deg,#5b0f55_0%,#9b123e_42%,#b45309_100%)]",
                ]}
              >
                <div class="absolute left-6 top-7 grid h-24 w-36 place-items-center rounded-[14px] border-2 border-dashed border-orange-200/70 bg-red-500/70 text-center text-xs font-semibold text-white shadow-xl dark:bg-red-500/45">
                  <span>
                    Upload Resume
                    <br />
                    <small class="font-medium opacity-80">or drag and drop</small>
                  </span>
                </div>

                <div class="absolute right-5 top-4 w-[56%] space-y-3">
                  {[0, 1, 2].map((item) => (
                    <div class="rounded-[14px] bg-white/92 p-3 text-[10px] text-slate-950 shadow-[0_12px_28px_rgba(15,23,42,0.18)] ring-1 ring-slate-900/5 dark:bg-slate-950/90 dark:text-white dark:ring-white/10">
                      <div class="mb-2 flex items-center justify-between">
                        <span class="text-[9px] text-slate-500 dark:text-slate-400">London, UK</span>
                        <span class="rounded-full bg-slate-950 px-3 py-1 text-[9px] font-semibold text-white shadow-[0_0_0_2px_rgba(255,255,255,0.45)] dark:bg-sky-500 dark:text-slate-950">
                          ✓ Auto Applied
                        </span>
                      </div>
                      <p class="font-bold leading-tight">
                        {item === 0
                          ? "Software Engineer Java Rust"
                          : item === 1
                            ? "Backend Engineer, Payments"
                            : "Product Analyst, Growth"}
                      </p>
                      <p class="mt-1 text-slate-500 dark:text-slate-400">
                        {item === 0 ? "Trading at Client Server Ltd." : item === 1 ? "Acme Corp LLC" : "Remote Team"}
                      </p>
                    </div>
                  ))}
                </div>
              </div>
            )}

            {feature.mock === "resumeBuilder" && (
              <div
                class:list={[
                  baseMockClass,
                  "bg-[linear-gradient(135deg,#ffb24f_0%,#ffd6c3_42%,#a18aff_100%)] dark:bg-[linear-gradient(135deg,#7c2d12_0%,#55215b_46%,#1d4ed8_100%)]",
                ]}
              >
                <div class="absolute inset-x-8 top-6 h-[170px] rounded-[18px] bg-white/88 p-5 shadow-[0_20px_50px_rgba(15,23,42,0.18)] ring-1 ring-slate-900/5 dark:bg-slate-950/88 dark:ring-white/10">
                  <div class="mb-4 h-3 w-20 rounded-full bg-slate-200 dark:bg-white/15" />
                  <div class="space-y-2">
                    <div class="h-3 w-full rounded-full bg-pink-100 dark:bg-pink-300/20" />
                    <div class="h-3 w-[86%] rounded-full bg-pink-100 dark:bg-pink-300/20" />
                    <div class="h-3 w-[72%] rounded-full bg-pink-100 dark:bg-pink-300/20" />
                  </div>
                  <div class="absolute left-[30%] top-[42%] h-20 w-[48%] rounded-sm border-2 border-slate-950/75 dark:border-white/75">
                    <span class="absolute -left-1 -top-1 size-2 bg-slate-950 dark:bg-white" />
                    <span class="absolute -right-1 -top-1 size-2 bg-slate-950 dark:bg-white" />
                    <span class="absolute -bottom-1 -left-1 size-2 bg-slate-950 dark:bg-white" />
                    <span class="absolute -bottom-1 -right-1 size-2 bg-slate-950 dark:bg-white" />
                  </div>
                </div>
                <div class="absolute bottom-5 left-1/2 flex -translate-x-1/2 items-center gap-2 rounded-full bg-slate-950 px-5 py-3 text-xs font-semibold text-white shadow-[0_10px_24px_rgba(15,23,42,0.3)] dark:bg-sky-500 dark:text-slate-950">
                  ✦ Rewrite Section
                </div>
              </div>
            )}

            {feature.mock === "coverLetter" && (
              <div
                class:list={[
                  baseMockClass,
                  "bg-[linear-gradient(135deg,#f5099d_0%,#ff6a2a_48%,#ffc15a_100%)] dark:bg-[linear-gradient(135deg,#701a75_0%,#9a3412_54%,#ca8a04_100%)]",
                ]}
              >
                <div class="absolute left-1/2 top-5 flex -translate-x-1/2 rounded-full bg-white/95 p-1 text-[9px] font-semibold text-slate-500 shadow-lg dark:bg-slate-950/90 dark:text-slate-300">
                  <span class="rounded-full bg-white px-3 py-1.5 text-slate-950 shadow dark:bg-slate-800 dark:text-white">Formal</span>
                  <span class="px-3 py-1.5">Proactive</span>
                  <span class="px-3 py-1.5">Concise</span>
                </div>
                <div class="absolute inset-x-7 bottom-[-18px] h-[145px] rounded-[14px] bg-white/82 p-5 shadow-[0_20px_42px_rgba(15,23,42,0.24)] ring-1 ring-white/60 dark:bg-slate-950/82 dark:ring-white/10">
                  <div class="mb-4 flex gap-2 text-pink-300 dark:text-pink-200/80">
                    <span>B</span><span>I</span><span>H</span><span>↔</span><span>⌘</span>
                  </div>
                  <div class="space-y-3">
                    <div class="h-4 w-[82%] rounded-full bg-slate-200/90 dark:bg-white/15" />
                    <div class="h-4 w-[94%] rounded-full bg-slate-200/90 dark:bg-white/15" />
                    <div class="h-4 w-[70%] rounded-full bg-slate-200/90 dark:bg-white/15" />
                  </div>
                  <div class="absolute bottom-6 left-1/2 -translate-x-1/2 rounded-full bg-slate-950 px-5 py-3 text-[11px] font-semibold text-white shadow-[0_10px_22px_rgba(15,23,42,0.32)] dark:bg-sky-500 dark:text-slate-950">
                    ⬇ Download Cover Letter PDF
                  </div>
                </div>
              </div>
            )}

            {feature.mock === "training" && (
              <div
                class:list={[
                  baseMockClass,
                  "bg-[linear-gradient(135deg,#f5099d_0%,#ff2f75_46%,#ff9b20_100%)] dark:bg-[linear-gradient(135deg,#701a75_0%,#9f1239_48%,#b45309_100%)]",
                ]}
              >
                <div class="absolute left-1/2 top-5 flex w-[76%] -translate-x-1/2 items-center justify-between rounded-full bg-white px-5 py-3 text-xs font-semibold text-slate-600 shadow-xl dark:bg-slate-950 dark:text-slate-200">
                  <span>“Can you work with JavaScript?”</span>
                  <span class="text-violet-600 dark:text-sky-300">✦</span>
                </div>
                <div class="absolute inset-x-8 top-[82px] h-[125px] rounded-[14px] bg-white/86 p-5 shadow-[0_16px_34px_rgba(15,23,42,0.2)] dark:bg-slate-950/86">
                  <p class="text-center text-[11px] font-bold text-slate-800 dark:text-white">Your Personalised Answer...</p>
                  <p class="mt-4 text-[10px] leading-relaxed text-slate-700 dark:text-slate-300">
                    “Absolutely, working with JavaScript has been a core component of my skillset as a software engineer.”
                  </p>
                  <div class="mt-4 space-y-2">
                    <div class="h-2 rounded-full bg-slate-200 dark:bg-white/15" />
                    <div class="h-2 w-[80%] rounded-full bg-slate-200 dark:bg-white/15" />
                  </div>
                </div>
              </div>
            )}

            {feature.mock === "buddy" && (
              <div
                class:list={[
                  baseMockClass,
                  "bg-[linear-gradient(135deg,#ff8a00_0%,#ff4d54_36%,#f0b3bd_58%,#bde4ff_100%)] dark:bg-[linear-gradient(135deg,#7c2d12_0%,#881337_38%,#312e81_72%,#075985_100%)]",
                ]}
              >
                <div class="absolute inset-x-7 top-7 h-[150px] rounded-[18px] bg-white/72 p-4 shadow-[0_18px_38px_rgba(15,23,42,0.2)] dark:bg-slate-950/72">
                  <div class="grid h-full grid-cols-[1fr_74px] gap-4">
                    <div class="rounded-[14px] bg-white/75 p-4 dark:bg-slate-900/80">
                      <div class="mx-auto size-16 rounded-full bg-slate-200 dark:bg-white/15" />
                      <div class="mt-5 h-3 rounded-full bg-slate-200 dark:bg-white/15" />
                      <div class="mt-2 h-3 w-[70%] rounded-full bg-slate-200 dark:bg-white/15" />
                    </div>
                    <div class="space-y-3">
                      <div class="h-16 rounded-[12px] bg-white/80 dark:bg-slate-900/80" />
                      <div class="h-16 rounded-[12px] bg-white/80 dark:bg-slate-900/80" />
                    </div>
                  </div>
                </div>
                <div class="absolute bottom-5 right-7 w-[46%] rounded-[14px] bg-white p-4 text-[10px] leading-snug text-slate-700 shadow-xl dark:bg-slate-950 dark:text-slate-300">
                  <p class="font-bold uppercase tracking-[0.08em] text-violet-500 dark:text-sky-300">Suggested answer...</p>
                  <p class="mt-2">“I can certainly tell you about a challenging project I launched in 2023...”</p>
                </div>
              </div>
            )}

            {feature.mock === "translate" && (
              <div
                class:list={[
                  baseMockClass,
                  "bg-[linear-gradient(135deg,#f5099d_0%,#ff5470_44%,#ff961f_100%)] dark:bg-[linear-gradient(135deg,#701a75_0%,#9f1239_48%,#b45309_100%)]",
                ]}
              >
                <div class="absolute left-7 top-6 rounded-full bg-white px-5 py-2 text-xs font-semibold text-slate-700 shadow-lg dark:bg-slate-950 dark:text-slate-200">
                  🇪🇸 Spanish ˅
                </div>
                <div class="absolute right-7 top-6 rounded-full bg-slate-950 px-5 py-2 text-xs font-semibold text-white shadow-lg dark:bg-sky-500 dark:text-slate-950">
                  ✦ Translate
                </div>
                <div class="absolute left-7 top-[70px] w-[46%] rounded-[16px] bg-pink-500/88 p-3 text-xs font-semibold text-white shadow-xl dark:bg-pink-700/85">
                  {["🇪🇸 Spanish", "🇬🇧 English", "🇫🇷 French", "🇨🇳 Chinese"].map((lang) => (
                    <div class="rounded-full px-3 py-2 hover:bg-white/15">{lang}</div>
                  ))}
                </div>
                <div class="absolute bottom-[-14px] right-7 h-[128px] w-[48%] rounded-[14px] bg-white/78 p-4 dark:bg-slate-950/78">
                  <div class="mb-3 h-3 w-20 rounded-full bg-slate-200 dark:bg-white/15" />
                  <div class="space-y-2">
                    <div class="h-3 rounded-full bg-slate-200 dark:bg-white/15" />
                    <div class="h-3 w-[78%] rounded-full bg-slate-200 dark:bg-white/15" />
                    <div class="h-3 w-[90%] rounded-full bg-slate-200 dark:bg-white/15" />
                  </div>
                </div>
              </div>
            )}
          </article>
        ))
      }
    </div>
  </div>
</section>
