---
const examples = [
  {
    title: "Инженер-программист",
    audience: "Для разработчиков, программистов и IT-специалистов",
    updated: "Обновлено 2 дня назад",
    name: "John Smith",
    role: "Инженер-программист",
    company: "Senior Developer · Tech Corp",
    period: "2020–2024",
    tags: ["Java", "React", "System"],
    accent: "bg-[linear-gradient(135deg,#fbf0ff_0%,#f7e8ff_54%,#e8d5ff_100%)] dark:bg-[linear-gradient(135deg,#2e1065_0%,#3b0764_56%,#1e1b4b_100%)]",
    tagClass: "bg-violet-100 text-violet-700 dark:bg-violet-300/15 dark:text-violet-100",
  },
  {
    title: "Менеджер по маркетингу",
    audience: "Для маркетологов и бренд-стратегов",
    updated: "Обновлено 3 дня назад",
    name: "Sarah Johnson",
    role: "Менеджер по маркетингу",
    company: "Marketing Lead · BrandCo",
    period: "2017–2019",
    tags: ["CRM", "Growth", "Brand"],
    accent: "bg-[linear-gradient(135deg,#eff8ff_0%,#e3f1ff_56%,#cfe6ff_100%)] dark:bg-[linear-gradient(135deg,#082f49_0%,#0f3b63_58%,#172554_100%)]",
    tagClass: "bg-sky-100 text-sky-700 dark:bg-sky-300/15 dark:text-sky-100",
  },
  {
    title: "Аналитик данных",
    audience: "Для data-специалистов и бизнес-аналитиков",
    updated: "Обновлено неделю назад",
    name: "Michael Chen",
    role: "Аналитик данных",
    company: "Senior Analyst · DataCorp",
    period: "2019–2021",
    tags: ["SQL", "Python", "Tableau"],
    accent: "bg-[linear-gradient(135deg,#eafff4_0%,#dbfbe9_56%,#c7f5dd_100%)] dark:bg-[linear-gradient(135deg,#052e1d_0%,#064e3b_58%,#052e2b_100%)]",
    tagClass: "bg-emerald-100 text-emerald-700 dark:bg-emerald-300/15 dark:text-emerald-100",
  },
  {
    title: "UX-дизайнер",
    audience: "Для дизайнеров и UX-профессионалов",
    updated: "Обновлено 5 дней назад",
    name: "Emma Rodriguez",
    role: "UX-дизайнер",
    company: "Senior UX Designer · DesignHub",
    period: "2019–2021",
    tags: ["Figma", "UX", "Research"],
    accent: "bg-[linear-gradient(135deg,#fff0f8_0%,#fde8f3_56%,#f9d4ea_100%)] dark:bg-[linear-gradient(135deg,#4a044e_0%,#831843_58%,#3b0764_100%)]",
    tagClass: "bg-pink-100 text-pink-700 dark:bg-pink-300/15 dark:text-pink-100",
  },
  {
    title: "Менеджер по продажам",
    audience: "Для продажников и бизнес-девелоперов",
    updated: "Обновлено 4 дня назад",
    name: "David Wilson",
    role: "Менеджер по продажам",
    company: "Regional Sales Manager · SalesCorp",
    period: "2020–2024",
    tags: ["CRM", "B2B", "KPI"],
    accent: "bg-[linear-gradient(135deg,#fff7ea_0%,#ffeed2_56%,#ffe0ad_100%)] dark:bg-[linear-gradient(135deg,#451a03_0%,#7c2d12_58%,#78350f_100%)]",
    tagClass: "bg-amber-100 text-amber-800 dark:bg-amber-300/15 dark:text-amber-100",
  },
  {
    title: "Проект-менеджер",
    audience: "Для проект-менеджеров и тимлидов",
    updated: "Обновлено вчера",
    name: "Lisa Thompson",
    role: "Проект-менеджер",
    company: "Senior PM · TechVentures",
    period: "2017–2019",
    tags: ["Agile", "Scrum", "Jira"],
    accent: "bg-[linear-gradient(135deg,#eef2ff_0%,#e4eaff_56%,#d8e0ff_100%)] dark:bg-[linear-gradient(135deg,#172554_0%,#312e81_58%,#1e1b4b_100%)]",
    tagClass: "bg-indigo-100 text-indigo-700 dark:bg-indigo-300/15 dark:text-indigo-100",
  },
] as const;
---

<section
  class="bg-[#f3f3f2] px-5 py-10 text-slate-950 dark:bg-[#03050a] dark:text-white sm:px-7 sm:py-12 lg:py-14"
  aria-labelledby="resume-it-examples-title"
>
  <div class="mx-auto w-full max-w-[1080px]">
    <div class="mx-auto max-w-4xl text-center">
      <h2
        id="resume-it-examples-title"
        class="text-[clamp(1.9rem,2.8vw,3.1rem)] font-semibold leading-[1.04] tracking-[-0.055em]"
      >
        Примеры IT-резюме для разных ролей
      </h2>
      <p class="mt-4 text-base font-medium text-slate-600 dark:text-slate-300 sm:text-lg">
        Используйте структуру и формулировки как основу для своего резюме в OfferGO
      </p>
    </div>

    <div class="mx-auto mt-16 grid max-w-[1040px] gap-5 sm:grid-cols-2 lg:mt-20 lg:grid-cols-3 lg:gap-6">
      {
        examples.map((example) => (
          <article class="group overflow-hidden rounded-[18px] bg-white shadow-[0_18px_45px_rgba(15,23,42,0.08)] ring-1 ring-slate-900/5 transition duration-300 hover:-translate-y-1 hover:shadow-[0_24px_60px_rgba(15,23,42,0.12)] dark:bg-slate-950/92 dark:ring-white/10 dark:hover:shadow-[0_24px_60px_rgba(2,132,199,0.14)]">
            <div class:list={["relative h-[190px] overflow-hidden", example.accent]}>
              <div class="absolute left-1/2 top-9 h-[138px] w-[68%] -translate-x-1/2 rotate-[3deg] rounded-[7px] bg-white/70 shadow-[0_14px_32px_rgba(15,23,42,0.12)] ring-1 ring-slate-900/5 dark:bg-slate-800/70 dark:ring-white/10" />
              <div class="absolute left-[52%] top-7 h-[148px] w-[68%] -translate-x-1/2 rotate-[1.4deg] rounded-[7px] bg-white/86 shadow-[0_16px_38px_rgba(15,23,42,0.13)] ring-1 ring-slate-900/5 dark:bg-slate-900/86 dark:ring-white/10" />
              <div class="absolute left-1/2 top-6 h-[158px] w-[70%] -translate-x-1/2 -rotate-[1.2deg] overflow-hidden rounded-[7px] bg-white p-4 text-[9px] leading-tight shadow-[0_18px_46px_rgba(15,23,42,0.16)] ring-1 ring-slate-900/5 dark:bg-slate-950 dark:ring-white/10">
                <div class="text-center">
                  <p class="text-[10px] font-bold text-slate-950 dark:text-white">{example.name}</p>
                  <p class="mt-0.5 text-[7px] font-medium text-slate-500 dark:text-slate-400">{example.role}</p>
                </div>
                <div class="mt-3 h-px bg-slate-200 dark:bg-white/10" />
                <div class="mt-3 space-y-2 text-slate-700 dark:text-slate-300">
                  <p class="font-bold text-slate-950 dark:text-white">Опыт</p>
                  <p>{example.company}</p>
                  <p>{example.period}</p>
                  <div class="h-px bg-slate-200 dark:bg-white/10" />
                  <p class="font-bold text-slate-950 dark:text-white">Навыки</p>
                  <div class="flex flex-wrap gap-1">
                    {example.tags.map((tag) => (
                      <span class:list={["rounded px-1.5 py-0.5 text-[7px] font-semibold", example.tagClass]}>{tag}</span>
                    ))}
                  </div>
                </div>
                <div class="pointer-events-none absolute inset-x-0 bottom-0 h-10 bg-gradient-to-t from-white via-white/90 to-transparent dark:from-slate-950 dark:via-slate-950/90" />
              </div>
            </div>

            <div class="p-7">
              <h3 class="text-xl font-semibold tracking-[-0.035em] text-slate-950 dark:text-white">{example.title}</h3>
              <p class="mt-4 min-h-[3rem] text-sm leading-relaxed text-slate-700 dark:text-slate-300">{example.audience}</p>
              <p class="mt-6 flex items-center gap-2 text-sm text-slate-500 dark:text-slate-400">
                <svg class="size-4 shrink-0" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                  <circle cx="12" cy="12" r="8.25" stroke="currentColor" stroke-width="1.8" />
                  <path d="M12 7.8v4.6l3.2 1.9" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" />
                </svg>
                <span>{example.updated}</span>
              </p>
            </div>
          </article>
        ))
      }
    </div>

    <div class="mt-12 flex justify-center">
      <a
        href="https://offergo.ru/resumes"
        class="inline-flex items-center justify-center rounded-full bg-white px-7 py-4 text-sm font-semibold text-slate-950 shadow-[0_14px_34px_rgba(15,23,42,0.08)] ring-1 ring-slate-900/5 transition hover:-translate-y-0.5 hover:shadow-[0_18px_44px_rgba(15,23,42,0.12)] focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-sky-500 dark:bg-slate-950 dark:text-white dark:ring-white/10"
      >
        Перейти к своим резюме
        <span class="ml-2" aria-hidden="true">→</span>
      </a>
    </div>
  </div>
</section>
