---
import DownloadButton from "@/components/DownloadButton.astro";
import { capabilities } from "@/data/site";
---

<section class="section capabilities" id="features" aria-labelledby="features-title">
  <div class="container">
    <div class="capabilities-head reveal">
      <h2 id="features-title">Что умеет ассистент?</h2>
      <p>offerGO слушает, анализирует, подсказывает и помогает быстрее пройти путь от подготовки к IT-собеседованию до отклика на вакансию.</p>
    </div>

    <div class="stepper">
      {
        capabilities.map((item, index) => (
          <article class:list={["stepper-item", index % 2 === 1 && "stepper-item--reverse", "reveal"]}>
            <div class="stepper-copy">
              <h3>{item.title}</h3>
              <p class="stepper-subtitle">{item.subtitle}</p>
              <p class="stepper-text">{item.text}</p>
            </div>

            <div class="stepper-rail" aria-hidden="true">
              <span class="stepper-node">{item.step}</span>
            </div>

            <div class="stepper-visual" aria-hidden="true">
              {item.visualType === "capture-shield" && (
                <img src="/promo/illustrations/step-1.png" alt="" loading="lazy" class="stepper-visual-image" />
              )}

              {item.visualType === "dual-audio" && (
                <div class="visual-panel visual-panel--signal">
                  <span>Вы</span>
                  <strong>Вопрос распознан</strong>
                  <div class="wave"><i></i><i></i><i></i><i></i><i></i><i></i></div>
                  <span>Собеседник</span>
                </div>
              )}

              {item.visualType === "speed-pipeline" && (
                <div class="visual-panel">
                  <span>Вопрос</span>
                  <strong>Как быстро ты отвечаешь?</strong>
                  <em>Ответ готов за секунды</em>
                </div>
              )}

              {item.visualType === "screenshot-flow" && (
                <div class="visual-panel">
                  <span>Скриншот</span>
                  <strong>Код, лог или задача на экране</strong>
                  <em>Результат возвращается в помощник</em>
                </div>
              )}

              {item.visualType === "price-compare" && (
                <div class="visual-panel visual-panel--price">
                  <span>Другие сервисы</span>
                  <strong>2-3 тыс. ₽</strong>
                  <span>offerGO</span>
                  <strong>1 000 ₽</strong>
                  <em>в месяц, без ограничений на ключевой сценарий</em>
                </div>
              )}
            </div>
          </article>
        ))
      }

      <article class="stepper-item stepper-item--final reveal">
        <div class="stepper-rail stepper-rail--cta">
          <DownloadButton label="Скачать для Windows" class="stepper-download" />
        </div>
      </article>
    </div>

    <div class="stepper-mobile-cta reveal">
      <DownloadButton label="Скачать для Windows" class="stepper-download stepper-download--mobile" />
    </div>
  </div>
</section>

<style>
  .capabilities .container {
    width: min(1220px, calc(100% - 56px));
  }

  .capabilities-head {
    max-width: 880px;
    margin: 0 auto 52px;
    text-align: center;
  }

  .capabilities-head h2 {
    margin: 0;
    font-family: "Space Grotesk", "Segoe UI", sans-serif;
    font-size: clamp(2.4rem, 5vw, 4.8rem);
    font-weight: 600;
    line-height: 0.92;
    letter-spacing: -0.08em;
    background: linear-gradient(90deg, var(--accent) 0%, var(--accent-2) 100%);
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
  }

  .capabilities-head p {
    margin: 16px auto 0;
    max-width: 760px;
    color: var(--soft);
    font-size: clamp(1rem, 1.3vw, 1.12rem);
    line-height: 1.7;
  }

  .stepper {
    position: relative;
    display: grid;
    gap: 58px;
  }

  .stepper::before {
    content: "";
    position: absolute;
    top: 8px;
    bottom: 8px;
    left: calc(50% - 1px);
    width: 2px;
    background: linear-gradient(180deg, rgba(59, 130, 246, 0.3), rgba(96, 165, 250, 0.62), rgba(59, 130, 246, 0.2));
  }

  .stepper-item {
    display: grid;
    grid-template-columns: minmax(0, 0.92fr) 76px minmax(0, 0.92fr);
    grid-template-areas: "copy rail visual";
    gap: 28px;
    align-items: center;
  }

  .stepper-item--reverse {
    grid-template-areas: "visual rail copy";
  }

  .stepper-copy {
    grid-area: copy;
    max-width: 420px;
  }

  .stepper-visual {
    grid-area: visual;
    justify-self: stretch;
    max-width: 460px;
  }

  .stepper-visual-image {
    display: block;
    width: 100%;
    height: auto;
    object-fit: contain;
  }

  .stepper-rail {
    grid-area: rail;
    display: grid;
    justify-items: center;
    position: relative;
    z-index: 1;
  }

  .stepper-node {
    display: grid;
    place-items: center;
    width: 56px;
    height: 56px;
    border-radius: 999px;
    border: 1px solid rgba(96, 165, 250, 0.36);
    background: var(--bg);
    color: var(--accent);
    font-family: "Space Grotesk", "Segoe UI", sans-serif;
    font-size: 0.9rem;
    font-weight: 700;
    letter-spacing: 0.08em;
  }

  .stepper-copy h3 {
    margin: 0;
    font-family: "Space Grotesk", "Segoe UI", sans-serif;
    font-size: clamp(1.7rem, 2.8vw, 2.9rem);
    font-weight: 600;
    line-height: 0.95;
    letter-spacing: -0.06em;
  }

  .stepper-subtitle {
    margin: 14px 0 0;
    color: var(--soft);
    font-size: 1rem;
    font-weight: 600;
    line-height: 1.55;
  }

  .stepper-text {
    margin: 14px 0 0;
    color: var(--soft);
    line-height: 1.8;
  }

  .visual-panel {
    display: grid;
    gap: 12px;
    border: 1px solid var(--line);
    border-radius: 8px;
    background: var(--panel);
    padding: 22px;
  }

  .visual-panel span {
    color: var(--muted);
    font-size: 0.78rem;
    font-weight: 800;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .visual-panel strong {
    color: var(--text);
    font-family: "Space Grotesk", "Segoe UI", sans-serif;
    font-size: clamp(1.35rem, 2.2vw, 2.2rem);
    line-height: 1;
    letter-spacing: -0.05em;
  }

  .visual-panel em {
    color: var(--soft);
    font-style: normal;
    line-height: 1.55;
  }

  .wave {
    display: flex;
    align-items: end;
    gap: 8px;
    min-height: 62px;
  }

  .wave i {
    flex: 1;
    border-radius: 999px;
    background: linear-gradient(180deg, var(--accent), rgba(96, 165, 250, 0.12));
  }

  .wave i:nth-child(1) { height: 28%; }
  .wave i:nth-child(2) { height: 72%; }
  .wave i:nth-child(3) { height: 44%; }
  .wave i:nth-child(4) { height: 88%; }
  .wave i:nth-child(5) { height: 54%; }
  .wave i:nth-child(6) { height: 68%; }

  .visual-panel--price strong:nth-of-type(2) {
    color: var(--accent);
  }

  .stepper-download {
    min-width: 236px;
    min-height: 44px;
    padding-inline: 16px;
    font-size: 0.92rem;
  }

  .stepper-item--final {
    grid-template-columns: 1fr auto 1fr;
    grid-template-areas: ". rail .";
    gap: 0;
  }

  .stepper-rail--cta {
    justify-items: center;
  }

  .stepper-mobile-cta {
    display: none;
    justify-content: center;
    margin-top: 34px;
  }

  @media (max-width: 920px) {
    .capabilities .container {
      width: min(100% - 40px, 1080px);
    }

    .stepper::before {
      left: 27px;
    }

    .stepper-item,
    .stepper-item--reverse {
      grid-template-columns: 54px 1fr;
      grid-template-areas:
        "rail copy"
        "rail visual";
      gap: 18px 22px;
    }

    .stepper-copy,
    .stepper-visual {
      max-width: none;
    }

    .stepper-item--final {
      display: none;
    }

    .stepper-mobile-cta {
      display: flex;
    }
  }

  @media (max-width: 620px) {
    .capabilities .container {
      width: min(100% - 40px, 1080px);
    }

    .capabilities-head {
      margin-bottom: 34px;
    }

    .capabilities-head h2 {
      font-size: clamp(2rem, 11vw, 3rem);
    }

    .stepper {
      gap: 42px;
    }

    .stepper-copy h3 {
      font-size: clamp(1.55rem, 8vw, 2.1rem);
    }

    .stepper-mobile-cta {
      margin-top: 28px;
    }

    .stepper-download--mobile {
      width: min(100%, 320px);
      min-width: 0;
      justify-content: center;
    }
  }
</style>
