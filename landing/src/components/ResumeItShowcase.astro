---
const jobs = [
  {
    icon: "◰",
    iconClass: "bg-violet-600 text-white dark:bg-sky-500",
    title: "Аналитик данных",
    subtitle: "FinTech команда",
    time: "3 ч",
    tags: ["Аналитика", "Python"],
    action: "Письмо готово",
    actionClass: "bg-violet-600 text-white dark:bg-sky-500",
  },
  {
    icon: "■",
    iconClass: "bg-[conic-gradient(#f25022_0_25%,#7fba00_0_50%,#00a4ef_0_75%,#ffb900_0)] text-transparent",
    title: "Product manager",
    subtitle: "Продуктовая команда",
    time: "4 ч",
    tags: ["Продукт", "B2B"],
    action: "Проверить",
    actionClass: "bg-orange-500 text-white dark:bg-orange-400 dark:text-slate-950",
  },
  {
    icon: "∞",
    iconClass: "bg-white text-blue-500 dark:bg-slate-800 dark:text-sky-300",
    title: "Frontend developer",
    subtitle: "Удалённая команда",
    time: "5h",
    tags: ["React", "TypeScript"],
    action: "Вставить",
    actionClass: "bg-violet-300 text-white dark:bg-sky-900 dark:text-sky-100",
  },
];
---

<section class="bg-[#f3f3f2] px-5 py-10 dark:bg-[#03050a] sm:px-7 sm:py-12 lg:py-14" aria-labelledby="resume-it-showcase-title">
  <h2 id="resume-it-showcase-title" class="sr-only">Возможности offerGO для резюме и откликов</h2>

  <div class="mx-auto grid w-full max-w-[1480px] gap-4 lg:grid-cols-3">
    <article class="relative h-[420px] overflow-hidden rounded-[34px] border border-slate-200/80 bg-white shadow-[0_18px_45px_rgba(15,23,42,0.12)] dark:border-sky-300/15 dark:bg-slate-950/95 dark:shadow-[0_22px_60px_rgba(2,132,199,0.14)]">
      <div class="flex flex-col items-start justify-between gap-3 px-7 pt-8 sm:flex-row sm:gap-5">
        <div class="flex items-start gap-5">
          <span class="mt-1 grid size-8 shrink-0 place-items-center rounded-xl bg-violet-600 text-white shadow-[0_8px_20px_rgba(109,40,217,0.28)] dark:bg-sky-500 dark:shadow-[0_8px_24px_rgba(56,189,248,0.28)]">
            <svg viewBox="0 0 24 24" class="size-5" aria-hidden="true">
              <path fill="currentColor" d="M12 3.5a3.5 3.5 0 0 1 3.5 3.5v1H17a2 2 0 0 1 2 2v8.5a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V10a2 2 0 0 1 2-2h1.5V7A3.5 3.5 0 0 1 12 3.5Zm-1.7 13h3.4l-.62-3.1a2 2 0 1 0-2.16 0l-.62 3.1ZM10 8h4V7a2 2 0 1 0-4 0v1Z" />
            </svg>
          </span>
          <h3 class="m-0 max-w-[13rem] text-2xl font-semibold leading-tight tracking-[-0.04em] text-slate-950 dark:text-white">
            Сопроводительное под вакансию
          </h3>
        </div>
      </div>

      <div class="absolute inset-x-0 bottom-0 flex justify-center px-8">
        <div class="relative h-[280px] w-[72%] min-w-[260px] max-w-[360px] translate-y-8 rotate-[-0.5deg] overflow-hidden rounded-[6px] bg-white shadow-[0_24px_60px_rgba(15,23,42,0.18)] ring-1 ring-slate-200 dark:bg-slate-900 dark:shadow-[0_24px_60px_rgba(0,0,0,0.34)] dark:ring-white/10">
          <div class="p-8 text-left text-[10px] leading-5 text-slate-700 dark:text-slate-300">
            <p class="mb-5 text-[9px] font-medium text-slate-500 dark:text-slate-400">Уважаемый HR-менеджер</p>
            <p>Откликаюсь на вашу вакансию. Вижу, что для роли важны релевантный стек, понятный опыт и умение быстро включаться в продуктовые задачи.</p>
            <p class="mt-4">В резюме я выделил проекты, технологии и результаты, которые напрямую совпадают с требованиями позиции.</p>
            <p class="mt-4">Буду рад обсудить, как мой опыт может быть полезен вашей команде.</p>
          </div>
          <div class="pointer-events-none absolute inset-x-0 bottom-0 h-28 bg-gradient-to-t from-white via-white/90 to-transparent dark:from-slate-900 dark:via-slate-900/90"></div>
        </div>
      </div>
    </article>

    <article class="relative h-[420px] overflow-hidden rounded-[34px] border border-slate-200/80 bg-white shadow-[0_18px_45px_rgba(15,23,42,0.12)] dark:border-sky-300/15 dark:bg-slate-950/95 dark:shadow-[0_22px_60px_rgba(2,132,199,0.14)]">
      <div class="flex flex-col items-start justify-between gap-3 px-7 pt-8 sm:flex-row sm:gap-5">
        <div class="flex items-start gap-5">
          <span class="mt-1 grid size-8 shrink-0 place-items-center rounded-xl bg-violet-600 text-white shadow-[0_8px_20px_rgba(109,40,217,0.28)] dark:bg-sky-500 dark:shadow-[0_8px_24px_rgba(56,189,248,0.28)]">
            <svg viewBox="0 0 24 24" class="size-5" aria-hidden="true">
              <path fill="currentColor" d="M7 3h10a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2Zm2 5h6V6H9v2Zm0 4h6.8v-1.5H9V12Zm0 3.2h5.8v-1.5H9v1.5Z" />
            </svg>
          </span>
          <h3 class="m-0 max-w-[13rem] text-2xl font-semibold leading-tight tracking-[-0.04em] text-slate-950 dark:text-white">
            Резюме под роль
          </h3>
        </div>
      </div>

      <div class="absolute inset-x-0 bottom-0 flex justify-center px-7">
        <div class="relative h-[282px] w-[74%] min-w-[270px] max-w-[370px] translate-y-8 overflow-hidden rounded-[6px] bg-white shadow-[0_24px_60px_rgba(15,23,42,0.18)] ring-1 ring-slate-200 dark:bg-slate-900 dark:shadow-[0_24px_60px_rgba(0,0,0,0.34)] dark:ring-white/10">
          <div class="p-6 text-left text-[9px] leading-4 text-slate-700 dark:text-slate-300">
            <h4 class="mb-3 text-center text-2xl font-black tracking-[-0.06em] text-slate-800 dark:text-white">Стив Джобс</h4>
            <div class="mb-4 flex flex-wrap justify-center gap-x-3 gap-y-1 text-[7px] text-slate-500 dark:text-slate-400">
              <span>Los Altos, CA</span>
              <span>steve@apple.com</span>
              <span>linkedin.com/stevejobs</span>
            </div>
            <div class="border-y border-slate-200 py-2 dark:border-white/10">
              <p class="font-bold uppercase tracking-[0.12em] text-slate-500 dark:text-sky-200/80">Сводка</p>
              <p class="mt-1">Визионер, предприниматель и инноватор в технологиях с историей запуска продуктов, которые меняли рынок.</p>
            </div>
            <div class="py-2">
              <p class="font-bold uppercase tracking-[0.12em] text-slate-500 dark:text-sky-200/80">Опыт</p>
              <p class="mt-1"><strong>Сооснователь, председатель и CEO</strong> | Apple Inc.</p>
              <p class="mt-1">Запустил Apple II, Macintosh, iMac, iPod, iPhone и App Store.</p>
            </div>
          </div>
          <div class="absolute inset-x-0 bottom-4 z-10 flex justify-center gap-2">
            <span class="rounded-full bg-violet-600 px-4 py-2 text-xs font-bold text-white shadow-lg dark:bg-sky-500">Harvard</span>
            <span class="rounded-full border border-slate-300 bg-white px-4 py-2 text-xs font-bold text-slate-700 shadow-lg dark:border-white/15 dark:bg-slate-950 dark:text-slate-200">Modern</span>
            <span class="rounded-full border border-slate-300 bg-white px-4 py-2 text-xs font-bold text-slate-700 shadow-lg dark:border-white/15 dark:bg-slate-950 dark:text-slate-200">Classic</span>
          </div>
          <div class="pointer-events-none absolute inset-x-0 bottom-0 h-20 bg-gradient-to-t from-white via-white/90 to-transparent dark:from-slate-900 dark:via-slate-900/90"></div>
        </div>
      </div>
    </article>

    <article class="relative h-[420px] overflow-hidden rounded-[34px] border border-slate-200/80 bg-white shadow-[0_18px_45px_rgba(15,23,42,0.12)] dark:border-sky-300/15 dark:bg-slate-950/95 dark:shadow-[0_22px_60px_rgba(2,132,199,0.14)]">
      <div class="flex flex-col items-start justify-between gap-3 px-7 pt-8 sm:flex-row sm:gap-5">
        <div class="flex items-start gap-5">
          <span class="mt-1 grid size-8 shrink-0 place-items-center rounded-xl bg-violet-600 text-white shadow-[0_8px_20px_rgba(109,40,217,0.28)] dark:bg-sky-500 dark:shadow-[0_8px_24px_rgba(56,189,248,0.28)]">
            <svg viewBox="0 0 24 24" class="size-5" aria-hidden="true">
              <path fill="currentColor" d="M4 7.5A2.5 2.5 0 0 1 6.5 5h11A2.5 2.5 0 0 1 20 7.5v9a2.5 2.5 0 0 1-2.5 2.5h-11A2.5 2.5 0 0 1 4 16.5v-9Zm2.2-.2 5.3 4.05a.8.8 0 0 0 .98 0l5.32-4.05a.9.9 0 0 0-.3-.05h-11a.9.9 0 0 0-.3.05Z" />
            </svg>
          </span>
          <h3 class="m-0 max-w-[13rem] text-2xl font-semibold leading-tight tracking-[-0.04em] text-slate-950 dark:text-white">
            Автоотклики в браузере
          </h3>
        </div>
      </div>

      <div class="absolute inset-x-0 top-[176px] grid gap-3 px-8 pb-5 sm:top-[150px]">
        {jobs.map((job) => (
          <div class="rounded-2xl border border-slate-200 bg-white p-3.5 text-left shadow-[0_7px_18px_rgba(15,23,42,0.12)] dark:border-white/10 dark:bg-slate-900 dark:shadow-[0_12px_26px_rgba(0,0,0,0.34)]">
            <div class="flex items-start justify-between gap-3">
              <div class="flex min-w-0 items-start gap-3">
                <span class:list={["mt-1 grid size-6 shrink-0 place-items-center rounded-md text-xs font-black", job.iconClass]}>{job.icon}</span>
                <div class="min-w-0">
                  <p class="m-0 truncate text-sm font-bold text-slate-950 dark:text-white">{job.title}</p>
                  <p class="m-0 text-xs font-medium text-slate-400 dark:text-slate-500">{job.subtitle}</p>
                </div>
              </div>
              <span class="shrink-0 text-xs font-medium text-slate-400 dark:text-slate-500">{job.time}</span>
            </div>
            <div class="mt-3 flex items-center justify-between gap-3">
              <div class="flex flex-wrap gap-1.5">
                {job.tags.map((tag) => <span class="rounded-full bg-slate-100 px-2.5 py-1 text-xs font-semibold text-slate-700 dark:bg-slate-800 dark:text-slate-200">{tag}</span>)}
              </div>
              <span class:list={["shrink-0 rounded-full px-3 py-1.5 text-xs font-bold", job.actionClass]}>{job.action}</span>
            </div>
          </div>
        ))}
        <div class="pointer-events-none absolute inset-x-0 bottom-0 h-20 bg-gradient-to-t from-white via-white/70 to-transparent dark:from-slate-950 dark:via-slate-950/70"></div>
      </div>
    </article>
  </div>
</section>
