---
const avatars = [
  { label: "FE", className: "bg-gradient-to-br from-cyan-300 to-blue-500 text-white" },
  { label: "FL", className: "bg-gradient-to-br from-sky-200 to-emerald-400 text-slate-950" },
  { label: "BE", className: "bg-gradient-to-br from-white to-blue-100 text-blue-950" },
];

const directions = ["Frontend", "Backend", "Mobile", "QA", "DevOps", "Data/ML", "Product", "UX/UI"];
---

<section class="px-5 pt-[calc(var(--header)+8px)] pb-6 sm:px-7" aria-labelledby="resume-it-hero-title">
  <div
    class="relative mx-auto flex min-h-[calc(100svh-var(--header)-32px)] w-full max-w-[1880px] items-center justify-center overflow-hidden rounded-[40px] bg-[#1838b7] px-5 py-10 text-center shadow-[0_34px_110px_rgba(7,19,71,0.44)] sm:px-8 lg:px-12"
  >
    <div class="pointer-events-none absolute inset-0">
      <div class="absolute -left-[12%] -top-[4%] h-[34vw] w-[30vw] rounded-full bg-[radial-gradient(circle,rgba(33,238,255,0.9)_0%,rgba(33,238,255,0.4)_38%,transparent_72%)] blur-[54px]"></div>
      <div class="absolute left-1/2 -top-[24%] h-[24vw] w-[36vw] -translate-x-1/2 rounded-full bg-[radial-gradient(circle,rgba(200,236,255,0.32)_0%,rgba(200,236,255,0.12)_42%,transparent_80%)] blur-[54px]"></div>
      <div class="absolute -right-[12%] -bottom-[16%] h-[24vw] w-[34vw] rounded-full bg-[radial-gradient(circle,rgba(149,255,177,0.64)_0%,rgba(149,255,177,0.22)_42%,transparent_74%)] blur-[54px]"></div>
      <div class="absolute -right-[16%] -bottom-[24%] h-[26vw] w-[42vw] rounded-full border-[48px] border-emerald-200/30 blur-[14px]"></div>
      <div
        class="absolute inset-0 bg-[radial-gradient(circle_at_1px_1px,rgba(255,255,255,0.1)_1px,transparent_0),linear-gradient(180deg,rgba(219,245,255,0.1),transparent_26%),linear-gradient(90deg,transparent_0_56%,rgba(77,245,255,0.12)_72%,transparent_88%)] bg-[length:26px_26px,100%_100%,100%_100%] [mask-image:linear-gradient(180deg,rgba(0,0,0,0.98),rgba(0,0,0,0.94)_76%,rgba(0,0,0,0.7))]"
      ></div>
      <div class="absolute inset-0 bg-[radial-gradient(circle_at_16%_2%,rgba(48,236,255,0.44),transparent_26%),radial-gradient(circle_at_52%_-8%,rgba(121,210,255,0.2),transparent_30%),radial-gradient(circle_at_88%_88%,rgba(134,255,179,0.34),transparent_24%),linear-gradient(180deg,rgba(17,37,166,0.98)_0%,rgba(23,56,188,0.97)_50%,rgba(16,44,163,0.95)_100%)]"></div>
    </div>

    <div class="relative z-10 mx-auto grid max-w-5xl justify-items-center">
      <h1
        id="resume-it-hero-title"
        class="max-w-5xl text-balance font-sans text-[clamp(2.35rem,4.35vw,4.05rem)] font-semibold leading-[0.94] tracking-[-0.045em] text-white"
      >
        <span class="block">Хватит подавать заявки неделями</span>
        <span class="relative z-0 mt-3 inline-block bg-[linear-gradient(90deg,#82f3ff_0%,#bcffd8_48%,#f0fff8_100%)] bg-clip-text pb-[0.08em] text-[clamp(2.85rem,5.1vw,5rem)] font-semibold italic leading-[1.08] tracking-[-0.05em] text-transparent [font-family:Georgia,'Times_New_Roman',serif] before:absolute before:inset-x-[8%] before:-bottom-2 before:-z-10 before:h-4 before:rounded-full before:bg-[linear-gradient(90deg,rgba(125,211,252,0)_0%,rgba(125,211,252,0.56)_38%,rgba(16,185,129,0.42)_68%,rgba(56,189,248,0)_100%)] before:blur-xl before:content-['']">
          Начните получать собеседования за дни
        </span>
      </h1>

      <p class="mt-6 max-w-4xl text-balance text-[clamp(0.95rem,1.18vw,1.08rem)] leading-[1.65] text-blue-50/95">
        offerGO помогает собрать резюме, проверить его ИИ-анализом, подготовить сопроводительное письмо
        под конкретную вакансию, найти IT-вакансии и подготовиться к собеседованию. Финальную отправку
        отклика всегда подтверждаете вы.
      </p>

      <div class="mt-7 flex flex-col items-center justify-center gap-5 sm:flex-row">
        <a
          class="inline-flex min-h-14 items-center justify-center gap-2 rounded-full !bg-white px-8 text-base font-extrabold !text-blue-700 shadow-[0_18px_40px_rgba(8,18,70,0.24)] transition hover:-translate-y-0.5 hover:!bg-blue-50 dark:!bg-white dark:!text-blue-700 dark:hover:!bg-blue-50 focus-visible:outline focus-visible:outline-4 focus-visible:outline-offset-4 focus-visible:outline-cyan-200"
          href="https://offergo.ru/resumes"
        >
          <span>Начать</span>
          <span aria-hidden="true">→</span>
        </a>

        <div class="flex items-center gap-3 text-left">
          <div class="flex -space-x-3" aria-hidden="true">
            {avatars.map((avatar) => (
              <span class:list={["grid size-10 place-items-center rounded-full border-2 border-white/90 text-[0.68rem] font-black tracking-wider shadow-lg", avatar.className]}>
                {avatar.label}
              </span>
            ))}
          </div>
          <div>
            <div class="text-sm font-black tracking-[0.1em] text-amber-300" aria-hidden="true">★★★★★</div>
            <p class="m-0 text-sm font-semibold text-blue-50/85">Доверяют 1 000+ пользователей</p>
          </div>
        </div>
      </div>

      <div class="mt-8 grid justify-items-center gap-3">
        <p class="m-0 text-sm font-semibold text-blue-100/70">Для IT и смежных digital-направлений</p>
        <ul class="m-0 flex flex-wrap items-center justify-center gap-x-8 gap-y-3 p-0 text-xl font-black tracking-[-0.04em] text-blue-100/45 sm:text-2xl" aria-label="Направления подготовки">
          {directions.map((direction) => <li class="list-none">{direction}</li>)}
        </ul>
      </div>
    </div>
  </div>
</section>
