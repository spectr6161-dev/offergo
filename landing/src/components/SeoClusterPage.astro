---
import { getRelatedSeoPages, type SeoClusterPage } from "@/data/seo-clusters";
import BaseLayout from "@/layouts/BaseLayout.astro";
import ResumeItHero from "@/components/ResumeItHero.astro";
import ResumeItExamplesSection from "@/components/ResumeItExamplesSection.astro";
import ResumeItFaqSection from "@/components/ResumeItFaqSection.astro";
import ResumeItFeaturesGrid from "@/components/ResumeItFeaturesGrid.astro";
import ResumeItSpeedSection from "@/components/ResumeItSpeedSection.astro";
import ResumeItShowcase from "@/components/ResumeItShowcase.astro";
import { resumeItFaqItems } from "@/data/resume-it-faq";
import {
  buildArticleJsonLd,
  buildFaqJsonLd,
  buildItemListJsonLd,
  buildWebPageJsonLd,
} from "@/lib/seo";

interface Props {
  page: SeoClusterPage;
}

const { page } = Astro.props;
const isResumeItPage = page.slug === "resume-it";
const relatedPages = isResumeItPage ? [] : getRelatedSeoPages(page);
const resolvedTitle = isResumeItPage
  ? "Проверка резюме IT — AI-анализ резюме программиста и подготовка к собеседованию"
  : page.title;
const resolvedDescription = isResumeItPage
  ? "AI-проверка резюме для IT-специалистов и смежных цифровых ролей: разработка, QA, DevOps, Data/ML, аналитика, продукт, дизайн, менеджмент, отклики и подготовка к IT-собеседованию."
  : page.description;
const resolvedKeywords = isResumeItPage
  ? ["проверка резюме IT", "резюме программиста", "резюме QA инженера", "резюме DevOps", "резюме аналитика данных", "резюме product manager", "резюме UX UI дизайнера", "IT вакансии"]
  : page.primaryKeywords;
const finalTitle = isResumeItPage
  ? "Проверка резюме IT — AI-анализ резюме программиста и подготовка к собеседованию"
  : resolvedTitle;
const finalDescription = isResumeItPage
  ? "AI-проверка резюме для IT-специалистов и смежных цифровых ролей: разработка, QA, DevOps, Data/ML, аналитика, продукт, дизайн, менеджмент, отклики и подготовка к IT-собеседованию."
  : resolvedDescription;
const finalKeywords = isResumeItPage
  ? ["проверка резюме IT", "резюме программиста", "резюме QA инженера", "резюме DevOps", "резюме аналитика данных", "резюме product manager", "резюме UX UI дизайнера", "IT вакансии"]
  : resolvedKeywords;
const jsonLd = [
  buildWebPageJsonLd({
    title: finalTitle,
    description: finalDescription,
    path: page.path,
    keywords: finalKeywords,
  }),
  buildArticleJsonLd({
    title: finalTitle,
    description: finalDescription,
    path: page.path,
    keywords: finalKeywords,
  }),
  buildFaqJsonLd(isResumeItPage ? resumeItFaqItems : page.faq),
  ...(relatedPages.length ? [buildItemListJsonLd(relatedPages.map((item) => ({ title: item.h1, path: item.path })))] : []),
];

---

<BaseLayout
  title={finalTitle}
  description={finalDescription}
  canonicalPath={page.path}
  jsonLd={jsonLd}
  pageType="article"
>
  <article class="seo-page">
    {isResumeItPage ? (
      <>
        <ResumeItHero />
        <ResumeItShowcase />
        <ResumeItSpeedSection />
        <ResumeItFeaturesGrid />
        <ResumeItExamplesSection />
        <ResumeItFaqSection />
      </>
    ) : (
      <>
        <section class="seo-hero" aria-labelledby="seo-title">
          <div class="container seo-hero__grid">
            <div class="seo-hero__copy reveal">
              <p class="eyebrow">{page.eyebrow}</p>
              <h1 id="seo-title">{page.h1}</h1>
              <p>{page.lead}</p>
              <div class="seo-hero__actions">
                <a class="btn btn-primary" href={page.cta.href}>{page.cta.label}</a>
                <a class="btn btn-secondary" href="/promo">Вернуться на главную</a>
              </div>
            </div>

            <aside class="seo-hero__keywords reveal" aria-label="Ключевые направления страницы">
              <span>Поисковые сценарии</span>
              <ul>
                {page.primaryKeywords.map((keyword) => <li>{keyword}</li>)}
              </ul>
            </aside>
          </div>
        </section>

        <section class="seo-section" aria-labelledby="seo-covers-title">
          <div class="container">
            <div class="seo-section__head reveal">
              <p class="eyebrow">Что закрывает страница</p>
              <h2 id="seo-covers-title">Практический маршрут от подготовки до отклика</h2>
            </div>

            <div class="seo-cards">
              {page.sections.map((section) => (
                <section class="seo-card reveal">
                  <h3>{section.title}</h3>
                  <p>{section.text}</p>
                </section>
              ))}
            </div>
          </div>
        </section>

        <section class="seo-section seo-section--split" aria-labelledby="seo-audience-title">
          <div class="container seo-split">
            <div class="reveal">
              <p class="eyebrow">Кому подходит</p>
              <h2 id="seo-audience-title">Для кандидатов на разных этапах поиска</h2>
            </div>

            <div class="seo-list reveal">
              {page.audiences.map((item) => (
                <div class="seo-list__item">
                  <span aria-hidden="true">✓</span>
                  <p>{item}</p>
                </div>
              ))}
            </div>
          </div>
        </section>

        <section class="seo-section" aria-labelledby="seo-helps-title">
          <div class="container">
            <div class="seo-section__head reveal">
              <p class="eyebrow">Как помогает offerGO</p>
              <h2 id="seo-helps-title">Связанные инструменты внутри продукта</h2>
            </div>

            <div class="seo-tools reveal">
              {page.helps.map((item) => <span>{item}</span>)}
            </div>
          </div>
        </section>

        <section class="seo-section seo-faq" aria-labelledby="seo-faq-title">
          <div class="container seo-faq__grid">
            <div class="reveal">
              <p class="eyebrow">FAQ</p>
              <h2 id="seo-faq-title">Частые вопросы</h2>
            </div>

            <div class="seo-faq__list">
              {page.faq.map((item) => (
                <details class="seo-faq__item reveal">
                  <summary>{item.question}</summary>
                  <p>{item.answer}</p>
                </details>
              ))}
            </div>
          </div>
        </section>

        <section class="seo-section seo-related" aria-labelledby="seo-related-title">
          <div class="container">
            <div class="seo-section__head reveal">
              <p class="eyebrow">Дальше</p>
              <h2 id="seo-related-title">Связанные разделы</h2>
            </div>

            <div class="seo-related__grid">
              {relatedPages.map((item) => (
                <a class="seo-related__item reveal" href={item.path}>
                  <span>{item.eyebrow}</span>
                  <strong>{item.h1}</strong>
                </a>
              ))}
            </div>
          </div>
        </section>
      </>
    )}
  </article>
</BaseLayout>

<style>
  .seo-page {
    background: var(--bg);
  }

  .seo-hero {
    padding: calc(var(--header) + 74px) 0 72px;
  }

  .seo-hero__grid {
    display: grid;
    grid-template-columns: minmax(0, 1.16fr) minmax(280px, 0.58fr);
    gap: 44px;
    align-items: end;
  }

  .seo-hero h1 {
    max-width: 960px;
    margin: 12px 0 0;
    font-family: "Space Grotesk", "Segoe UI", sans-serif;
    font-size: clamp(3rem, 7vw, 6.8rem);
    font-weight: 600;
    line-height: 0.9;
    letter-spacing: -0.08em;
  }

  .seo-hero__copy > p:not(.eyebrow) {
    max-width: 760px;
    margin: 24px 0 0;
    color: var(--soft);
    font-size: clamp(1rem, 1.5vw, 1.22rem);
    line-height: 1.72;
  }

  .seo-hero__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    margin-top: 30px;
  }

  .seo-hero__keywords {
    display: grid;
    gap: 16px;
    border-left: 1px solid var(--line);
    padding-left: 24px;
  }

  .seo-hero__keywords span {
    color: var(--accent);
    font-size: 0.78rem;
    font-weight: 800;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  .seo-hero__keywords ul {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .seo-hero__keywords li,
  .seo-tools span {
    display: inline-flex;
    align-items: center;
    min-height: 34px;
    border: 1px solid var(--line);
    border-radius: 999px;
    padding: 0 12px;
    color: var(--soft);
    font-size: 0.9rem;
    font-weight: 700;
  }

  .seo-section {
    padding: 68px 0;
  }

  .seo-section__head {
    max-width: 780px;
    margin-bottom: 28px;
  }

  .seo-section h2,
  .seo-faq h2 {
    margin: 12px 0 0;
    color: var(--text);
    font-family: "Space Grotesk", "Segoe UI", sans-serif;
    font-size: clamp(2rem, 4vw, 4rem);
    font-weight: 600;
    line-height: 0.96;
    letter-spacing: -0.07em;
  }

  .seo-cards {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 14px;
  }

  .seo-card {
    border-top: 1px solid var(--line);
    padding-top: 22px;
  }

  .seo-card h3 {
    margin: 0;
    font-family: "Space Grotesk", "Segoe UI", sans-serif;
    font-size: clamp(1.35rem, 2vw, 2rem);
    font-weight: 600;
    line-height: 1;
    letter-spacing: -0.05em;
  }

  .seo-card p {
    margin: 14px 0 0;
    color: var(--muted);
    line-height: 1.72;
  }

  .seo-split {
    display: grid;
    grid-template-columns: 0.82fr 1.18fr;
    gap: 44px;
    align-items: start;
  }

  .seo-list {
    display: grid;
    gap: 14px;
  }

  .seo-list__item {
    display: grid;
    grid-template-columns: 28px 1fr;
    gap: 14px;
    align-items: start;
    border-top: 1px solid var(--line);
    padding-top: 14px;
  }

  .seo-list__item span {
    color: var(--accent);
    font-weight: 900;
  }

  .seo-list__item p {
    margin: 0;
    color: var(--soft);
    font-weight: 700;
    line-height: 1.55;
  }

  .seo-tools {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
  }

  .seo-faq__grid {
    display: grid;
    grid-template-columns: 0.62fr 1.38fr;
    gap: 44px;
    align-items: start;
  }

  .seo-faq__list {
    display: grid;
    gap: 10px;
  }

  .seo-faq__item {
    border-top: 1px solid var(--line);
    padding: 18px 0;
  }

  .seo-faq__item summary {
    cursor: pointer;
    color: var(--text);
    font-weight: 900;
  }

  .seo-faq__item p {
    margin: 14px 0 0;
    color: var(--muted);
    line-height: 1.7;
  }

  .seo-related__grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 14px;
  }

  .seo-related__item {
    display: grid;
    gap: 10px;
    border: 1px solid var(--line);
    border-radius: 8px;
    padding: 20px;
    transition:
      transform 180ms var(--ease),
      border-color 180ms var(--ease);
  }

  .seo-related__item:hover {
    transform: translateY(-2px);
    border-color: var(--line-strong);
  }

  .seo-related__item span {
    color: var(--accent);
    font-size: 0.74rem;
    font-weight: 800;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .seo-related__item strong {
    color: var(--text);
    font-family: "Space Grotesk", "Segoe UI", sans-serif;
    font-size: 1.18rem;
    line-height: 1.1;
  }

  @media (max-width: 980px) {
    .seo-hero__grid,
    .seo-split,
    .seo-faq__grid {
      grid-template-columns: 1fr;
    }

    .seo-hero__keywords {
      border-left: 0;
      border-top: 1px solid var(--line);
      padding: 22px 0 0;
    }

    .seo-cards,
    .seo-related__grid {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 620px) {
    .seo-hero {
      padding-top: calc(var(--header) + 46px);
    }

    .seo-hero__actions .btn {
      width: 100%;
    }
  }
</style>
