---
import { seoClusterPages } from "@/data/seo-clusters";

const featured = seoClusterPages.slice(0, 7);
---

<nav class="seo-hub sr-only" aria-label="SEO-разделы подготовки к собеседованию и поиску работы">
  <h2>Подготовка к IT-собеседованию, вакансии и резюме</h2>
  <ul>
    {featured.map((page) => (
      <li>
        <a href={page.path}>
          {page.h1}: {page.primaryKeywords.join(", ")}
        </a>
      </li>
    ))}
  </ul>
</nav>
