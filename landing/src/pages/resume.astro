---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { ResumeWorkspace } from "@/components/ResumeWorkspace/index";
import BrandWordmark from "@/components/BrandWordmark.astro";
import { brand } from "@/data/site";
import { buildWebPageJsonLd } from "@/lib/seo";

const initialMode = Astro.url.searchParams.get("mode");
const chooserStep = Astro.url.searchParams.get("step") === "chooser";
const workspaceMode = initialMode === "workspace";

const title = workspaceMode ? "Анализ резюме | offerGO" : "AI-анализ резюме и улучшение откликов | offerGO";
const description = workspaceMode
  ? "Загрузите резюме и получите разбор спорных мест, ошибок и улучшений прямо в документе."
  : "Проверяйте резюме через AI, находите слабые формулировки и улучшайте документ перед откликами и собеседованиями.";

const jsonLd = buildWebPageJsonLd({
  title,
  description,
  path: "/promo/resume",
  keywords: ["проверка резюме IT", "резюме программиста", "AI анализ резюме", "помощь с резюме IT"],
});
---

<BaseLayout title={title} description={description} canonicalPath="/promo/resume" jsonLd={jsonLd}>
  {workspaceMode ? (
    <section class="section resume-page">
      <div class="container">
        <ResumeWorkspace client:load apiBase={brand.apiBaseUrl} initialMode={initialMode} />
      </div>
    </section>
  ) : chooserStep ? (
    <section class="section resume-page">
      <div class="container">
        <ResumeWorkspace client:load apiBase={brand.apiBaseUrl} initialMode="path-select" />
      </div>
    </section>
  ) : (
    <section class="resume-landing">
      <div class="container resume-landing__container">
        <div class="resume-landing__brand reveal">
          <BrandWordmark size="md" class="resume-landing__wordmark" />
        </div>

        <div class="resume-landing__intro reveal">
          <p class="eyebrow">Резюме разработчика</p>
          <h1>Проверьте резюме перед откликами и техническим интервью</h1>
          <p>
            AI-анализ помогает найти слабые формулировки, усилить описание проектов, показать стек и подготовить резюме под React, Flutter, Backend и другие IT-вакансии.
          </p>
        </div>

        <div class="resume-landing__grid reveal">
          <article>
            <span>01</span>
            <h2>Создайте резюме</h2>
            <p>Соберите структуру, опыт, навыки и проекты в понятный документ для рекрутера и технического интервью.</p>
          </article>
          <article>
            <span>02</span>
            <h2>Запустите AI-анализ</h2>
            <p>Получите замечания по слабым местам, конкретике, стеку, достижениям и соответствию вакансии.</p>
          </article>
          <article>
            <span>03</span>
            <h2>Переходите к откликам</h2>
            <p>Используйте обновленное резюме для индивидуальных сопроводительных писем и подготовки к собеседованию.</p>
          </article>
        </div>

        <div class="resume-landing__actions reveal">
          <a class="resume-landing__cta" href="/promo/resume?step=chooser">Перейти к резюме</a>
          <a class="resume-landing__secondary" href="/promo/resume-it">Как улучшить IT-резюме</a>
        </div>
      </div>
    </section>
  )}
</BaseLayout>

<style>
  .resume-page {
    padding-top: var(--header);
    padding-bottom: 0;
    background: var(--bg);
  }

  :root[data-theme="dark"] .resume-page {
    background: #000;
  }

  .resume-page .container {
    width: 100%;
    max-width: none;
    padding: 0;
    position: relative;
    z-index: 1;
  }

  .resume-landing {
    min-height: calc(100svh - var(--header));
    padding: calc(var(--header) + 54px) 0 74px;
    background: var(--bg);
  }

  .resume-landing__container {
    width: min(1120px, calc(100% - 32px));
  }

  .resume-landing__brand {
    display: flex;
    justify-content: center;
  }

  .resume-landing__intro {
    max-width: 820px;
    margin: 34px auto 0;
    text-align: center;
  }

  .resume-landing__intro h1 {
    margin: 12px 0 0;
    color: var(--text);
    font-family: "Space Grotesk", "Segoe UI", sans-serif;
    font-size: clamp(2.6rem, 6vw, 5.8rem);
    font-weight: 700;
    line-height: 0.92;
    letter-spacing: -0.08em;
  }

  .resume-landing__intro p:not(.eyebrow) {
    max-width: 720px;
    margin: 22px auto 0;
    color: var(--soft);
    font-size: clamp(1rem, 1.5vw, 1.2rem);
    line-height: 1.7;
  }

  .resume-landing__grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 14px;
    margin-top: 42px;
  }

  .resume-landing__grid article {
    border-top: 1px solid var(--line);
    padding-top: 18px;
  }

  .resume-landing__grid span {
    color: var(--accent);
    font-family: "Space Grotesk", "Segoe UI", sans-serif;
    font-weight: 800;
  }

  .resume-landing__grid h2 {
    margin: 12px 0 0;
    color: var(--text);
    font-family: "Space Grotesk", "Segoe UI", sans-serif;
    font-size: 1.5rem;
    letter-spacing: -0.05em;
  }

  .resume-landing__grid p {
    margin: 12px 0 0;
    color: var(--muted);
    line-height: 1.65;
  }

  .resume-landing__actions {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 12px;
    margin-top: 42px;
  }

  .resume-landing__cta,
  .resume-landing__secondary {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 56px;
    border-radius: 8px;
    padding: 0 22px;
    font-weight: 800;
  }

  .resume-landing__cta {
    background: var(--accent);
    color: #fff;
  }

  .resume-landing__secondary {
    border: 1px solid var(--line);
    background: var(--panel);
    color: var(--text);
  }

  @media (max-width: 860px) {
    .resume-landing__grid {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 620px) {
    .resume-landing__actions a {
      width: 100%;
    }
  }
</style>
