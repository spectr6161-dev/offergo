---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { ResumeWorkspace } from "@/components/ResumeWorkspace/index";
import BrandWordmark from "@/components/BrandWordmark.astro";
import { brand } from "@/data/site";

const initialMode = Astro.url.searchParams.get("mode");
const chooserStep = Astro.url.searchParams.get("step") === "chooser";
const workspaceMode = initialMode === "workspace";

const title = workspaceMode
  ? "Анализ резюме | offerGO"
  : "AI-анализ резюме и улучшение откликов | offerGO";

const description = workspaceMode
  ? "Загрузите резюме и получите разбор спорных мест, ошибок и улучшений прямо в документе."
  : "Проверяйте резюме через AI, находите слабые формулировки и улучшайте документ перед откликами и собеседованиями.";

const beforePoints = [
  "Слабые формулировки без результата",
  "Шумные навыки и плохая структура",
  "Ручная правка без понимания ATS",
];

const afterPoints = [
  "Умный AI-разбор резюме",
  "Готовые замены текста",
  "Больше шансов на собеседование",
];

const proofCards = [
  {
    title: "475 человек получили приглашения на собеседования",
    chips: [
      "jessi2***@gmail.com",
      "johnad***@yahoo.com",
      "pantov***@proton.me",
      "olmatt***@gmail.com",
    ],
    tone: "yellow",
  },
  {
    title: "177 человек нашли работу",
    chips: [
      "kristi***@gmail.com",
      "thomas***@gmail.com",
      "ulanar***@outlook.com",
      "xpatri***@protonmail.com",
    ],
    tone: "violet",
  },
];
---

<BaseLayout title={title} description={description}>
  {workspaceMode ? (
    <section class="section resume-page">
      <div class="container">
        <ResumeWorkspace client:load apiBase={brand.apiBaseUrl} initialMode={initialMode} />
      </div>
    </section>
  ) : chooserStep ? (
    <section class="section resume-page">
      <div class="container">
        <ResumeWorkspace client:load apiBase={brand.apiBaseUrl} initialMode="path-select" />
      </div>
    </section>
  ) : (
    <section class="resume-landing">
      <div class="container resume-landing__container">
        <div class="resume-landing__brand reveal">
          <BrandWordmark size="md" class="resume-landing__wordmark" />
        </div>

        <div class="resume-landing__line reveal" aria-hidden="true"></div>

        <div class="resume-landing__intro reveal">
          <h1>Ускорьте карьеру с AI-анализом резюме</h1>
          <p>
            Более 50 000 соискателей уже улучшают резюме с нашей платформой. Мы
            совмещаем ИИ и практичные рекомендации, чтобы быстрее получать отклики.
            <strong> Результаты говорят сами за себя!</strong>
          </p>
        </div>

        <div class="resume-landing__compare reveal">
          <article class="resume-card resume-card--before">
            <span class="resume-card__badge resume-card__badge--dark">До</span>
            <div class="resume-card__visual resume-card__visual--mono">
              <img src="/promo/resume/before-person.png" alt="Кандидат до улучшения резюме" loading="eager" />
            </div>
            <div class="resume-card__note">
              <div class="resume-card__logos resume-card__logos--before">
                <span>hh.ru</span>
                <span>хабр.карьера</span>
              </div>
              <span class="resume-card__emoji" aria-hidden="true">😔</span>
              <ul>
                {beforePoints.map((point) => <li>{point}</li>)}
              </ul>
            </div>
          </article>

          <article class="resume-card resume-card--after">
            <span class="resume-card__badge resume-card__badge--blue">После</span>
            <div class="resume-card__visual">
              <img src="/promo/resume/after-person.png" alt="Кандидат после AI-анализа резюме" loading="eager" />
            </div>
            <div class="resume-card__note">
              <div class="resume-card__logos resume-card__logos--after">
                <span>offerGO</span>
              </div>
              <span class="resume-card__emoji resume-card__emoji--right" aria-hidden="true">🤩</span>
              <ul>
                {afterPoints.map((point) => <li>{point}</li>)}
              </ul>
            </div>
          </article>
        </div>

        <p class="resume-landing__proof-title reveal">За последние 24 часа:</p>

        <div class="resume-landing__proof-grid reveal">
          {proofCards.map((card) => (
            <article class="resume-proof">
              <h2>{card.title}</h2>
              <div class="resume-proof__chips">
                {card.chips.map((chip) => (
                  <span class={`resume-proof__chip resume-proof__chip--${card.tone}`}>{chip}</span>
                ))}
              </div>
            </article>
          ))}
        </div>

        <div class="resume-landing__actions reveal">
          <a class="resume-landing__cta" href="/promo/resume?step=chooser">Далее</a>
        </div>
      </div>
    </section>
  )}
</BaseLayout>

<style>
  .resume-page {
    padding-top: var(--header);
    padding-bottom: 0;
    background: var(--bg);
  }

  :root[data-theme="dark"] .resume-page {
    background: #000;
  }

  .resume-page .container {
    width: 100%;
    max-width: none;
    padding: 0;
    position: relative;
    z-index: 1;
  }

  .resume-landing {
    padding: calc(var(--header) + 18px) 0 54px;
    background: #fff;
  }

  :root[data-theme="dark"] .resume-landing {
    background: #06101b;
  }

  .resume-landing__container {
    width: min(980px, calc(100% - 32px));
  }

  .resume-landing__brand {
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .resume-landing__wordmark {
    transform: scale(1.28);
    transform-origin: center;
  }

  .resume-landing__line {
    width: min(420px, 100%);
    height: 12px;
    margin: 14px auto 0;
    border-radius: 999px;
    background: linear-gradient(180deg, var(--accent-2) 0%, var(--accent) 100%);
    box-shadow: inset 0 0 0 2px rgba(255, 255, 255, 0.92), 0 4px 10px rgba(59, 130, 246, 0.2);
  }

  :root[data-theme="dark"] .resume-landing__line {
    box-shadow: inset 0 0 0 2px rgba(255, 255, 255, 0.18), 0 4px 18px rgba(59, 130, 246, 0.22);
  }

  .resume-landing__intro {
    max-width: 730px;
    margin: 18px auto 0;
    text-align: center;
    color: var(--text);
  }

  .resume-landing__intro h1 {
    margin: 0;
    font-size: clamp(2.35rem, 4.2vw, 3.4rem);
    line-height: 1.04;
    letter-spacing: -0.05em;
    font-weight: 800;
  }

  .resume-landing__intro p {
    margin: 18px auto 0;
    max-width: 690px;
    color: var(--muted);
    font-size: clamp(1rem, 1.5vw, 1.22rem);
    line-height: 1.65;
    font-weight: 500;
  }

  .resume-landing__intro strong {
    color: var(--text);
    font-weight: 800;
  }

  .resume-landing__compare {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 18px;
    margin-top: 34px;
  }

  .resume-card {
    position: relative;
    min-height: 365px;
    overflow: hidden;
    border-radius: 20px;
    border: 1px solid rgba(16, 24, 40, 0.06);
  }

  .resume-card--before {
    background: #e8edf2;
  }

  .resume-card--after {
    background: #e7f2ff;
  }

  :root[data-theme="dark"] .resume-card--before {
    background: #0e1822;
    border-color: rgba(148, 163, 184, 0.12);
  }

  :root[data-theme="dark"] .resume-card--after {
    background: #0d2236;
    border-color: rgba(59, 130, 246, 0.16);
  }

  .resume-card__badge {
    position: absolute;
    top: 16px;
    left: 16px;
    z-index: 3;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 42px;
    height: 28px;
    padding: 0 12px;
    border-radius: 999px;
    font-size: 0.88rem;
    font-weight: 800;
    color: #fff;
  }

  .resume-card__badge--dark {
    background: #232326;
  }

  .resume-card__badge--blue {
    background: var(--accent);
  }

  .resume-card__visual {
    position: absolute;
    left: 18px;
    right: 44%;
    bottom: 0;
    display: flex;
    align-items: flex-end;
    justify-content: center;
    height: 100%;
  }

  .resume-card__visual img {
    width: 100%;
    max-width: 268px;
    height: auto;
    object-fit: contain;
    object-position: bottom center;
  }

  .resume-card__visual--mono img {
    filter: grayscale(1);
  }

  .resume-card__note {
    position: absolute;
    top: 78px;
    right: 16px;
    width: 50%;
    min-height: 240px;
    padding: 26px 18px 22px;
    border-radius: 18px;
    background: rgba(255, 255, 255, 0.95);
    box-shadow: 0 8px 22px rgba(15, 23, 42, 0.07);
  }

  :root[data-theme="dark"] .resume-card__note {
    background: rgba(10, 17, 27, 0.94);
    box-shadow: 0 10px 22px rgba(0, 0, 0, 0.18);
  }

  .resume-card__logos {
    display: grid;
    gap: 8px;
    color: #595a60;
    font-size: 1.1rem;
    font-weight: 800;
    letter-spacing: -0.04em;
  }

  :root[data-theme="dark"] .resume-card__logos {
    color: #d5deea;
  }

  .resume-card__logos--before {
    justify-items: center;
    margin-top: 8px;
  }

  .resume-card__logos--after {
    color: var(--accent);
    justify-items: start;
    font-family: "Space Grotesk", "Segoe UI", sans-serif;
    font-size: 1.45rem;
  }

  .resume-card__emoji {
    position: absolute;
    top: 14px;
    right: 16px;
    font-size: 2rem;
  }

  .resume-card__emoji--right {
    top: -10px;
    right: -2px;
    font-size: 2.35rem;
  }

  .resume-card__note ul {
    margin: 20px 0 0;
    padding-left: 18px;
    color: #575862;
    font-size: 0.98rem;
    line-height: 1.6;
    font-weight: 600;
  }

  :root[data-theme="dark"] .resume-card__note ul {
    color: #d7e1ee;
  }

  .resume-landing__proof-title {
    margin: 34px 0 0;
    text-align: center;
    color: var(--soft);
    font-size: 1.06rem;
    font-weight: 700;
  }

  .resume-landing__proof-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 18px;
    margin-top: 16px;
  }

  .resume-proof {
    padding: 20px 18px 18px;
    border: 1px solid rgba(16, 24, 40, 0.08);
    border-radius: 16px;
    background: #fff;
    box-shadow: 0 2px 10px rgba(15, 23, 42, 0.04);
  }

  :root[data-theme="dark"] .resume-proof {
    border-color: rgba(148, 163, 184, 0.14);
    background: #09121d;
    box-shadow: none;
  }

  .resume-proof h2 {
    margin: 0;
    color: var(--text);
    font-size: 1rem;
    line-height: 1.5;
    font-weight: 800;
  }

  .resume-proof__chips {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-top: 16px;
  }

  .resume-proof__chip {
    display: inline-flex;
    align-items: center;
    min-height: 34px;
    padding: 0 10px;
    border-radius: 6px;
    font-size: 0.96rem;
    font-weight: 500;
    color: #2f3040;
  }

  .resume-proof__chip--yellow {
    background: #fff4a8;
  }

  .resume-proof__chip--violet {
    background: #dceeff;
  }

  :root[data-theme="dark"] .resume-proof__chip {
    color: #e7eef8;
  }

  :root[data-theme="dark"] .resume-proof__chip--yellow {
    background: rgba(250, 204, 21, 0.18);
  }

  :root[data-theme="dark"] .resume-proof__chip--violet {
    background: rgba(59, 130, 246, 0.22);
  }

  .resume-landing__actions {
    display: flex;
    justify-content: center;
    margin-top: 34px;
  }

  .resume-landing__cta {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: min(360px, 100%);
    min-height: 62px;
    border-radius: 999px;
    background: linear-gradient(180deg, var(--accent-2) 0%, var(--accent) 100%);
    box-shadow: inset 0 0 0 2px rgba(255, 255, 255, 0.22);
    color: #fff;
    font-size: 1.45rem;
    font-weight: 700;
    letter-spacing: -0.03em;
    transition: transform 180ms var(--ease), filter 180ms var(--ease);
  }

  .resume-landing__cta:hover {
    transform: translateY(-2px);
    filter: brightness(1.04);
  }

  :root[data-theme="dark"] .resume-landing__cta {
    box-shadow: inset 0 0 0 2px rgba(255, 255, 255, 0.12), 0 8px 22px rgba(59, 130, 246, 0.22);
  }

  @media (max-width: 900px) {
    .resume-landing {
      padding-top: calc(var(--header) + 24px);
    }

    .resume-landing__container {
      width: min(100% - 20px, 980px);
    }

    .resume-landing__compare,
    .resume-landing__proof-grid {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 640px) {
    .resume-card {
      min-height: 0;
      padding: 58px 14px 14px;
    }

    .resume-card__visual,
    .resume-card__note {
      position: relative;
      top: auto;
      right: auto;
      left: auto;
      width: 100%;
    }

    .resume-card__visual {
      height: 240px;
      margin-bottom: 12px;
    }

    .resume-card__visual img {
      max-width: 220px;
      max-height: 100%;
    }

    .resume-card__note {
      min-height: 0;
      padding-top: 22px;
    }

    .resume-card__emoji--right {
      top: 10px;
      right: 14px;
    }

    .resume-landing__cta {
      font-size: 1.22rem;
    }
  }
</style>
