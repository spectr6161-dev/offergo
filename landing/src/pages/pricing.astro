---
import BaseLayout from "@/layouts/BaseLayout.astro";
import FinalCta from "@/components/FinalCta.astro";
import DownloadButton from "@/components/DownloadButton.astro";
import { pricing } from "@/data/site";
import { buildWebPageJsonLd } from "@/lib/seo";

const title = "Тарифы offerGO — помощник для IT-собеседований";
const description = "Тарифы offerGO для подготовки к IT-собеседованиям, проверки резюме, откликов и Windows-помощника.";
---

<BaseLayout title={title} description={description} canonicalPath="/promo/pricing" jsonLd={buildWebPageJsonLd({ title, description, path: "/promo/pricing" })}>
  <section class="page-hero">
    <div class="container">
      <p class="eyebrow">Pricing</p>
      <h1>Тарифы без лишней сложности</h1>
      <p>На первом этапе продукт доступен как beta/pilot. Windows-помощник уже можно скачать, а платные тарифы остаются ориентиром для полного доступа.</p>
    </div>
  </section>
  <section class="page-section">
    <div class="container pricing-page-grid">
      {pricing.map((plan) => (
        <article class:list={["pricing-page-card", { highlighted: plan.highlighted }]}>
          <h2>{plan.name}</h2>
          <div>
            <strong>{plan.price}</strong>
            <span>{plan.period}</span>
          </div>
          <p>{plan.description}</p>
          <ul>
            {plan.features.map((feature) => <li>{feature}</li>)}
          </ul>
          <DownloadButton variant={plan.highlighted ? "primary" : "secondary"} animated={plan.highlighted} />
        </article>
      ))}
    </div>
  </section>
  <FinalCta />
</BaseLayout>

<style>
  .page-hero {
    padding: calc(var(--header) + 80px) 0 56px;
  }

  .page-hero h1 {
    max-width: 820px;
    margin: 12px 0 18px;
    font-family: "Space Grotesk", "Segoe UI", sans-serif;
    font-size: clamp(3rem, 8vw, 7rem);
    line-height: 0.88;
    letter-spacing: -0.08em;
  }

  .page-hero p:not(.eyebrow) {
    max-width: 660px;
    margin: 0;
    color: var(--muted);
    line-height: 1.7;
  }

  .page-section {
    padding: 40px 0 80px;
  }

  .pricing-page-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 14px;
  }

  .pricing-page-card {
    display: flex;
    flex-direction: column;
    border: 1px solid var(--line);
    border-radius: 8px;
    background: var(--panel);
    padding: 28px;
  }

  .pricing-page-card.highlighted {
    border-color: var(--line-strong);
    box-shadow: var(--shadow);
  }

  .pricing-page-card h2 {
    margin: 0 0 18px;
    font-family: "Space Grotesk", "Segoe UI", sans-serif;
    font-size: 2rem;
  }

  .pricing-page-card strong {
    display: block;
    font-family: "Space Grotesk", "Segoe UI", sans-serif;
    font-size: 2.5rem;
  }

  .pricing-page-card span,
  .pricing-page-card p,
  .pricing-page-card li {
    color: var(--muted);
  }

  .pricing-page-card ul {
    display: grid;
    gap: 10px;
    margin: 22px 0 28px;
    padding-left: 20px;
  }

  .pricing-page-card .btn {
    margin-top: auto;
  }

  @media (max-width: 900px) {
    .pricing-page-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
