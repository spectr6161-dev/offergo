---
import AuthLayout from "@/layouts/AuthLayout.astro";
import { brand } from "@/data/site";
---

<AuthLayout title="Подтверждение входа | offerGO" description="Подтверждение входа в Windows-клиент">
  <section class="auth-panel">
    <div class="auth-panel-copy">
      <p class="auth-panel-kicker">Подтверждение</p>
      <h2>Вход в приложение</h2>
      <p id="device-description">Войдите на сайте и подтвердите вход в Windows-клиент.</p>
    </div>

    <div id="device-auth-required" class="device-state" hidden>
      <p class="auth-feedback">Сначала войдите или зарегистрируйтесь в браузере.</p>
      <div class="device-actions">
        <a id="device-login-link" class="btn btn-primary auth-submit" href="/promo/auth/login">Войти</a>
        <a id="device-register-link" class="btn btn-secondary auth-submit secondary-submit" href="/promo/auth/register">Регистрация</a>
      </div>
    </div>

    <div id="device-approve-panel" class="device-state" hidden>
      <div class="device-summary">
        <div>
          <span>Аккаунт</span>
          <strong id="device-user">Неизвестно</strong>
        </div>
        <div>
          <span>Устройство</span>
          <strong id="device-name">Windows-клиент</strong>
        </div>
      </div>
      <button id="device-approve-button" class="btn btn-primary auth-submit" type="button">Подтвердить вход</button>
    </div>

    <p id="auth-feedback" class="auth-feedback" aria-live="polite"></p>

    <div class="auth-links">
      <a href="/promo">На главную</a>
    </div>
  </section>
</AuthLayout>

<script define:vars={{ apiBaseUrl: brand.apiBaseUrl }} is:inline>
  const feedback = document.getElementById("auth-feedback");
  const loginBlock = document.getElementById("device-auth-required");
  const approveBlock = document.getElementById("device-approve-panel");
  const loginLink = document.getElementById("device-login-link");
  const registerLink = document.getElementById("device-register-link");
  const approveButton = document.getElementById("device-approve-button");
  const deviceUser = document.getElementById("device-user");
  const deviceName = document.getElementById("device-name");
  const description = document.getElementById("device-description");

  const url = new URL(window.location.href);
  const userCode = url.searchParams.get("user_code") || "";
  const desktopName = url.searchParams.get("deviceName") || "Windows-клиент";
  const returnTo = `/auth/device${window.location.search}`;

  deviceName.textContent = desktopName;
  description.textContent = userCode
    ? "Подтвердите вход в приложении. Код вводить не нужно."
    : "Ссылка подтверждения неполная. Запустите вход из Windows-клиента заново.";

  loginLink.href = `/auth/login?returnTo=${encodeURIComponent(returnTo)}`;
  registerLink.href = `/auth/register?returnTo=${encodeURIComponent(returnTo)}`;

  async function loadSession() {
    if (!userCode) {
      feedback.textContent = "Не удалось открыть подтверждение входа.";
      return;
    }

    const response = await fetch(`${apiBaseUrl}/auth/me`, {
      credentials: "include",
    });

    if (!response.ok) {
      loginBlock.hidden = false;
      return;
    }

    const data = await response.json().catch(() => null);
    if (!data?.user) {
      loginBlock.hidden = false;
      return;
    }

    approveBlock.hidden = false;
    deviceUser.textContent = data.user.email || data.user.displayName || "Неизвестно";
  }

  approveButton?.addEventListener("click", async () => {
    feedback.textContent = "Подтверждаем вход...";

    try {
      const response = await fetch(`${apiBaseUrl}/auth/app/browser/approve`, {
        method: "POST",
        credentials: "include",
        headers: {
          "Content-Type": "application/json",
        },
        body: JSON.stringify({ userCode }),
      });

      const data = await response.json().catch(() => ({}));
      if (!response.ok) {
        feedback.textContent = data?.message || data?.error_description || "Не удалось подтвердить вход.";
        return;
      }

      feedback.textContent = "Готово. Вернитесь в приложение.";
      approveButton.disabled = true;
    } catch (error) {
      feedback.textContent = error instanceof Error ? error.message : "Не удалось подключиться к серверу.";
    }
  });

  loadSession().catch((error) => {
    feedback.textContent = error instanceof Error ? error.message : "Не удалось загрузить состояние входа.";
  });
</script>

<style>
  .auth-panel {
    display: grid;
    gap: 20px;
  }

  .auth-panel-copy {
    display: grid;
    gap: 8px;
  }

  .auth-panel-kicker {
    margin: 0;
    color: var(--accent-2);
    font-size: 0.78rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    font-weight: 700;
  }

  .auth-panel h2 {
    margin: 0;
    font-size: 1.9rem;
    line-height: 1;
    letter-spacing: -0.05em;
    font-weight: 600;
  }

  .auth-panel-copy p:last-child,
  .auth-feedback {
    margin: 0;
    color: var(--muted);
    line-height: 1.6;
  }

  .device-state {
    display: grid;
    gap: 16px;
  }

  .device-summary {
    display: grid;
    gap: 14px;
    padding: 18px;
    border: 1px solid var(--line);
    border-radius: 8px;
    background: var(--panel);
  }

  .device-summary div {
    display: grid;
    gap: 4px;
  }

  .device-summary span {
    color: var(--muted);
    font-size: 0.82rem;
  }

  .device-actions {
    display: grid;
    gap: 10px;
  }

  .auth-submit {
    width: 100%;
    min-height: 52px;
  }

  .secondary-submit {
    background: var(--panel);
  }

  .auth-links a {
    color: var(--soft);
    font-size: 0.94rem;
  }
</style>
