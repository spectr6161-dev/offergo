{
  "name": "@offergo/db",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc -p tsconfig.json",
    "format:check": "prettier --check \"src/**/*.ts\" \"prisma/**/*.ts\" && prettier --plugin prettier-plugin-prisma --check \"prisma/**/*.prisma\"",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "^6.18.0",
    "@offergo/shared": "workspace:*",
    "dotenv": "^16.6.1"
  },
  "devDependencies": {
    "@types/node": "^22.15.21",
    "eslint": "^9.39.1",
    "prettier": "^3.6.2",
    "prettier-plugin-prisma": "^5.0.0",
    "prisma": "^6.18.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
