generator client {
  provider = "prisma-client-js"
  output   = "../generated/client"
}

generator adminjsClient {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum AppRole {
  user
  admin
  support
}

enum BillingProvider {
  platega
}

enum PaymentStatus {
  pending
  confirmed
  canceled
  chargebacked
  expired
}

enum EntitlementStatus {
  active
  expired
  revoked
}

enum ResumeStatus {
  draft
  uploaded
  analyzed
  failed
}

enum ResumeVersionSource {
  uploaded
  ai_rewrite
  manual
}

enum TrainerSessionStatus {
  queued
  active
  completed
  failed
}

enum TrainerMessageRole {
  system
  assistant
  user
}

enum JobStatus {
  queued
  running
  completed
  failed
}

enum JobAttemptStatus {
  running
  completed
  failed
}

enum FilePurpose {
  resume_source
  resume_export
  screenshot
  temp_ai_output
}

model User {
  id                  String               @id @default(cuid())
  name                String
  email               String               @unique
  emailVerified       Boolean              @default(false)
  image               String?
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  accounts            Account[]
  sessions            Session[]
  roleAssignments     RoleAssignment[]
  passwordResetTokens PasswordResetToken[]
  payments            Payment[]
  entitlements        Entitlement[]
  resumes             Resume[]
  trainerSessions     TrainerSession[]
  files               FileAsset[]
  auditLogs           AuditLog[]           @relation("AuditActor")
}

model Session {
  id             String   @id @default(cuid())
  expiresAt      DateTime
  token          String   @unique
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  ipAddress      String?
  userAgent      String?
  userId         String
  impersonatedBy String?
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Account {
  id                    String    @id @default(cuid())
  accountId             String
  providerId            String
  userId                String
  accessToken           String?
  refreshToken          String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  idToken               String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([providerId, accountId])
}

model Verification {
  id         String   @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([identifier, value])
}

model Jwks {
  id         String    @id @default(cuid())
  publicKey  String
  privateKey String
  alg        String?
  crv        String?
  createdAt  DateTime  @default(now())
  expiresAt  DateTime?

  @@map("jwks")
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model RoleAssignment {
  id        String   @id @default(cuid())
  userId    String
  role      AppRole
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, role])
}

model Plan {
  id               String        @id @default(dbgenerated("gen_random_uuid()::text"))
  code             String        @unique @default(dbgenerated("gen_random_uuid()::text"))
  name             String
  description      String?
  priceRub         Int
  subscriptionType String        @default("custom")
  durationDays     Int           @default(30)
  active           Boolean       @default(true)
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @default(now()) @updatedAt
  payments         Payment[]
  entitlements     Entitlement[]
}

model Payment {
  id                    String          @id @default(cuid())
  provider              BillingProvider
  providerTransactionId String?         @unique
  userId                String
  planId                String
  status                PaymentStatus   @default(pending)
  amountRub             Int
  currency              String          @default("RUB")
  paymentUrl            String?
  providerPayload       Json?
  createdAt             DateTime        @default(now())
  updatedAt             DateTime        @updatedAt
  expiresAt             DateTime?
  confirmedAt           DateTime?
  canceledAt            DateTime?
  chargebackedAt        DateTime?
  entitlement           Entitlement?
  plan                  Plan            @relation(fields: [planId], references: [id])
  user                  User            @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Entitlement {
  id              String            @id @default(cuid())
  userId          String
  planId          String
  status          EntitlementStatus @default(active)
  startsAt        DateTime
  endsAt          DateTime
  sourcePaymentId String?           @unique
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  plan            Plan              @relation(fields: [planId], references: [id])
  payment         Payment?          @relation(fields: [sourcePaymentId], references: [id])
  user            User              @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Resume {
  id               String          @id @default(cuid())
  userId           String
  title            String
  status           ResumeStatus    @default(draft)
  originalFileId   String?
  currentVersionId String?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  versions         ResumeVersion[]
  user             User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  originalFile     FileAsset?      @relation("ResumeOriginalFile", fields: [originalFileId], references: [id])
}

model ResumeVersion {
  id        String              @id @default(cuid())
  resumeId  String
  source    ResumeVersionSource
  plainText String?
  content   Json?
  summary   String?
  createdAt DateTime            @default(now())
  resume    Resume              @relation(fields: [resumeId], references: [id], onDelete: Cascade)
}

model Question {
  id         String        @id @default(cuid())
  slug       String        @unique
  title      String
  answer     Json?
  difficulty String?
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt
  tags       QuestionTag[]
}

model QuestionTag {
  id        String     @id @default(cuid())
  slug      String     @unique
  name      String     @unique
  createdAt DateTime   @default(now())
  questions Question[]
}

model TrainerSession {
  id        String               @id @default(cuid())
  userId    String
  topic     String
  status    TrainerSessionStatus @default(queued)
  createdAt DateTime             @default(now())
  updatedAt DateTime             @updatedAt
  messages  TrainerMessage[]
  user      User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model TrainerMessage {
  id        String             @id @default(cuid())
  sessionId String
  role      TrainerMessageRole
  content   Json
  createdAt DateTime           @default(now())
  session   TrainerSession     @relation(fields: [sessionId], references: [id], onDelete: Cascade)
}

model Job {
  id            String       @id @default(cuid())
  queue         String
  name          String
  providerJobId String?
  status        JobStatus    @default(queued)
  payload       Json
  result        Json?
  error         String?
  attempts      Int          @default(0)
  scheduledAt   DateTime?
  lastRunAt     DateTime?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  attemptsLog   JobAttempt[]
}

model JobAttempt {
  id         String           @id @default(cuid())
  jobId      String
  status     JobAttemptStatus
  startedAt  DateTime
  finishedAt DateTime?
  error      String?
  createdAt  DateTime         @default(now())
  job        Job              @relation(fields: [jobId], references: [id], onDelete: Cascade)
}

model FileAsset {
  id            String      @id @default(cuid())
  ownerId       String?
  bucket        String
  objectKey     String      @unique
  mimeType      String
  size          Int
  purpose       FilePurpose
  checksum      String?
  createdAt     DateTime    @default(now())
  owner         User?       @relation(fields: [ownerId], references: [id], onDelete: SetNull)
  sourceResumes Resume[]    @relation("ResumeOriginalFile")
}

model AuditLog {
  id          String   @id @default(cuid())
  actorUserId String?
  targetType  String
  targetId    String
  action      String
  metadata    Json?
  createdAt   DateTime @default(now())
  actor       User?    @relation("AuditActor", fields: [actorUserId], references: [id], onDelete: SetNull)
}

model AdminJsSession {
  sid    String   @id(map: "session_pkey") @db.VarChar
  sess   Json     @db.Json
  expire DateTime @db.Timestamp(6)

  @@index([expire], map: "IDX_session_expire")
  @@map("adminjs_session")
}
