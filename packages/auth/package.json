{
  "name": "@offergo/auth",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./client": "./src/client.ts",
    "./server": "./src/server.ts",
    "./session": "./src/session.ts",
    "./core": "./src/core.ts"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "lint": "eslint src --ext .ts --ext .tsx",
    "typecheck": "tsc -p tsconfig.json",
    "format:check": "prettier --check \"src/**/*.{ts,tsx}\""
  },
  "dependencies": {
    "@opentelemetry/api": "^1.9.0",
    "@better-auth/prisma-adapter": "^1.4.14",
    "@offergo/db": "workspace:*",
    "@offergo/shared": "workspace:*",
    "better-auth": "^1.3.7",
    "next": "16.2.4",
    "nodemailer": "^6.10.1",
    "react": "19.2.4",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@types/node": "^22.15.21",
    "@types/nodemailer": "^6.4.17",
    "eslint": "^9.39.1",
    "prettier": "^3.6.2",
    "typescript": "^5.9.3"
  }
}
